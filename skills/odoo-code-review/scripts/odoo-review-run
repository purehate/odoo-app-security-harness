ANSI_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]|\x1b[()][A-Za-z0-9]")


def clean_output(text: str) -> str:
    """Strip terminal control noise from CLI/model output before logs/artifacts."""
    return ANSI_RE.sub("", text).replace("\r", "\n")


def progress(message: str) -> None:
    print(f"[odoo-review-run] {message}", flush=True)


def is_http_url(value: str) -> bool:
    parsed = urlparse(value)
    return parsed.scheme in {"http", "https"} and bool(parsed.netloc)


def validate_runtime_targets(args: argparse.Namespace) -> list[str]:
    errors: list[str] = []
    if getattr(args, "zap_target", None) and not is_http_url(args.zap_target):
        errors.append("--zap-target must be an http(s) URL")
    odoomap_target = getattr(args, "odoomap_target", None)
    if odoomap_target and odoomap_target != "self" and not is_http_url(odoomap_target):
        errors.append("--odoomap-target must be 'self' or an http(s) URL")
    return errors


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run repeatable setup for the odoo-code-review Odoo audit harness.")
    parser.add_argument("target", nargs="?", default=".", help="Odoo repo/addons path. Defaults to current directory.")
    parser.add_argument("--out", help="Output directory. Defaults to <target>/.audit-YYYYMMDD-HHMM (stamped per run).")
    parser.add_argument("--prune-old-runs", type=int, metavar="N", help="After successful run, keep only the most recent N stamped <target>/.audit-YYYYMMDD-HHMM/ dirs.")
    parser.add_argument("--modules", help="Comma-separated module names to include")
    parser.add_argument("--odoo-version", help="Override Odoo version in run plan")
    parser.add_argument("--config", dest="project_config", help="Project config TOML. Defaults to .odoo-review/config.toml or .odoo-review.toml when present.")
    parser.add_argument("--model-pack", choices=sorted(MODEL_PACKS.keys()), default="default", help="Model/lane preset. Default: default.")
    parser.add_argument("--quick", action="store_true", help="Skip automated scanners and discourse prep")
    parser.add_argument("--no-discourse", action="store_true")
    parser.add_argument("--no-local-qwen", action="store_true", help="Skip Ollama/Qwen advisory pass")
    parser.add_argument("--local-model", default=DEFAULT_MODEL, help=f"Ollama model. Default: {DEFAULT_MODEL}")
    parser.add_argument("--allow-missing-lanes", action="store_true", help="Continue if Codex or Qwen is unavailable")
    parser.add_argument("--joern", action="store_true", help="Run Joern if installed")
    parser.add_argument("--runtime", action="store_true", help="Enable Phase 7.5 runtime evidence path; use odoo-review-runtime <OUT> to boot Odoo and replay PoCs.")
    parser.add_argument("--zap-target", help="ZAP target URL; requires --runtime")
    parser.add_argument("--odoomap-target", help="Authorized QA/staging URL or 'self' for optional OdooMap runtime recon. Requires --runtime.")
    parser.add_argument("--no-codex", action="store_true", help="Skip Codex hunter execution")
    parser.add_argument("--codex-model", default="gpt-5.3-codex", help="Codex model")
    parser.add_argument("--codex-budget", choices=["low", "normal", "deep"], default="normal")
    parser.add_argument("--codex-mode", choices=["run", "prepare"], default="run", help="Run Codex tasks or only write prompts")
    parser.add_argument("--ensemble", choices=["off", "cheap", "balanced"], default="off", help="Run additional focused recall passes before Phase 7 validation. Default: off.")
    parser.add_argument("--ensemble-passes", type=int, default=0, help="Number of ensemble recall passes. 0 means preset default.")
    parser.add_argument("--requirements", help="Requirements/spec file for Phase 7.8")
    parser.add_argument("--no-html", action="store_true")
    parser.add_argument("--no-json", action="store_true", dest="no_emit_json", help="Skip findings.json sidecar (emitted by default).")
    parser.add_argument("--json", action="store_true", dest="emit_json", help="(Compat) findings.json is on by default; flag is a no-op kept for legacy invocations.")
    parser.add_argument("--no-export", action="store_true", help="Skip Phase 8.6 auto-export (SARIF/fingerprints/bounty/diff). Default: on.")
    parser.add_argument("--baseline", help="Baseline findings.json or .audit/ for Phase 8.6 auto-diff. Default: <target>/.audit-baseline/findings.json if present.")
    parser.add_argument("--preflight-only", action="store_true", help="Write run plan/tooling, then stop")
    parser.add_argument("--no-scans", action="store_true", help="Skip scanners even when not --quick")
    parser.add_argument("--scope", help="Path to scope.yml accepted-risks file (suppresses matching findings).")
    parser.add_argument("--pr", help="GitHub PR number; scope review to files changed in this PR (requires gh CLI).")
    parser.add_argument("--pr-repo", help="GitHub repo (owner/name) for --pr; defaults to gh-detected origin.")
    parser.add_argument("--accepted-risks", help="Path to per-finding accepted-risks suppression file (YAML or JSON). Defaults to <repo>/.audit-accepted-risks.{yml,yaml,json}.")
    parser.add_argument("--check-only-accepted-risks", action="store_true", help="Validate accepted-risks file, write inventory, then exit. Non-zero on errors or expired entries.")
    parser.add_argument("--fix-list", help="Path to fix-it list tracking file (YAML or JSON). Defaults to <repo>/.audit-fix-list.{yml,yaml,json}.")
    parser.add_argument("--check-only-fix-list", action="store_true", help="Validate fix-list file, write inventory, then exit. Non-zero on validation errors or overdue open/in-progress entries.")
    parser.add_argument("--no-server-actions", action="store_true", help="Skip docs/server_actions/*.py loose-Python sweep (default: include).")
    parser.add_argument("--no-scripts", action="store_true", help="Skip scripts/*.py loose-Python sweep (default: include).")
    parser.add_argument("--no-breadth", action="store_true", help="Skip Phase 1.7 breadth-sweep dispatch plan emission (same as --breadth-budget off).")
    parser.add_argument("--breadth-budget", choices=["off", "low", "normal", "deep"], default="normal", help="Phase 1.7 Claude subagent budget. off=none, low=top 8 risky chunks, normal=top 24 risky chunks, deep=all chunks. Default: normal.")
    parser.add_argument("--breadth-max-chunks", type=int, default=0, help="Hard cap Phase 1.7 breadth chunks after risk prioritization. 0 uses --breadth-budget default.")
    parser.add_argument("--breadth-chunk-size", type=int, default=40, help="Files per breadth-sweep subagent chunk. Default: 40.")
    parser.add_argument("--phase1-min-lines-per-module", type=int, default=4, help="Phase 1 fail-loud threshold: minimum lines of attack-surface content per in-scope module. Default: 4.")
    parser.add_argument("--no-phase1-assert", action="store_true", help="Disable Phase 1 fail-loud assertion (escape hatch; not recommended).")
    parser.add_argument("--allow-empty-scope", action="store_true", help="Allow runs with zero discovered Odoo modules/pseudo-modules. By default this fails before scanner/model lanes to avoid quota waste on the wrong target.")
    parser.add_argument("--yes", "-y", action="store_true", dest="non_interactive", help="Non-interactive: strip every Claude/orchestration y/N prompt. With --learn, auto-applies Phase 8.7 suggestions up to iteration cap.")
    parser.add_argument("--learn", action="store_true", help="After final findings exist, generate baseline/fix-list/accepted-risk learning artifacts. Apply accepted-risk suppressions only when --yes is also set.")
    parser.add_argument("--learn-cap", type=int, default=3, help="Max Phase 8.7 self-improvement iterations under --learn. Default: 3.")
    parser.add_argument("--baseline-stock-cc", action="store_true", help="Spawn one stock Claude Code control lane reviewing the same repo with no harness; stock-only findings become current-run validation leads and future hunter lessons.")
    parser.add_argument("-ks", "--ks", "--kitchensink", "--weekly", action="store_true", dest="weekly", help="Kitchen sink: max-quality review path. Enables Joern, runtime evidence path, breadth, JSON, learn, stock-CC gate, and durable state auto-detect. Add --yes separately for zero prompts.")
    args = parser.parse_args()
    # findings.json is now emitted by default. --json kept as compat no-op; --no-json opts out.
    args.emit_json = not args.no_emit_json
    # -ks/--kitchensink expands to the max-quality config.
    if args.weekly:
        args.joern = True
        args.runtime = True
        args.learn = True
        args.baseline_stock_cc = True
        # default-on lanes stay on unless the caller explicitly disabled them.
        if not cli_flag_present("--no-discourse"):
            args.no_discourse = False
        if not cli_flag_present("--no-local-qwen"):
            args.no_local_qwen = False
        if not cli_flag_present("--no-codex"):
            args.no_codex = False
        if not cli_flag_present("--no-breadth"):
            args.no_breadth = False
        if not cli_flag_present("--no-export"):
            args.no_export = False
        if not cli_flag_present("--no-html"):
            args.no_html = False
        args.no_emit_json = False
        args.emit_json = True
        if not cli_flag_present("--breadth-budget"):
            args.breadth_budget = "deep"
    return args


def cli_flag_present(*flags: str) -> bool:
    return any(arg == flag or arg.startswith(flag + "=") for arg in sys.argv[1:] for flag in flags)


def load_project_config(args: argparse.Namespace, repo: Path) -> tuple[dict, Path | None, list[str]]:
    warnings: list[str] = []
    candidates = [Path(args.project_config).expanduser().resolve()] if args.project_config else [repo / p for p in CONFIG_FILES]
    chosen = next((p for p in candidates if p.exists()), None)
    if not chosen:
        return {}, None, warnings
    if tomllib is None:
        warnings.append(f"{chosen}: TOML config requires Python 3.11+ tomllib; config ignored.")
        return {}, chosen, warnings
    try:
        with chosen.open("rb") as handle:
            data = tomllib.load(handle)
    except Exception as exc:  # noqa: BLE001
        warnings.append(f"{chosen}: could not parse TOML config: {exc}")
        return {}, chosen, warnings
    if not isinstance(data, dict):
        warnings.append(f"{chosen}: top-level config must be a TOML table.")
        return {}, chosen, warnings
    return data, chosen, warnings


def apply_value(args: argparse.Namespace, attr: str, value: object, *flags: str) -> None:
    if value is None or cli_flag_present(*flags):
        return
    setattr(args, attr, value)


def apply_project_config(args: argparse.Namespace, repo: Path) -> tuple[dict, Path | None, list[str]]:
    config, path, warnings = load_project_config(args, repo)
    models = config.get("models", {}) if isinstance(config.get("models"), dict) else {}
    runtime = config.get("runtime", {}) if isinstance(config.get("runtime"), dict) else {}
    odoo = config.get("odoo", {}) if isinstance(config.get("odoo"), dict) else {}
    review = config.get("review", {}) if isinstance(config.get("review"), dict) else {}

    apply_value(args, "model_pack", models.get("model_pack"), "--model-pack")
    if args.model_pack not in MODEL_PACKS:
        warnings.append(f"{path}: unknown model_pack {args.model_pack!r}; using default.")
        args.model_pack = "default"
    pack = MODEL_PACKS.get(args.model_pack, {})
    apply_value(args, "codex_model", pack.get("codex_model"), "--codex-model")
    apply_value(args, "codex_budget", pack.get("codex_budget"), "--codex-budget")
    apply_value(args, "local_model", pack.get("local_model"), "--local-model")
    if pack.get("no_codex") and not cli_flag_present("--no-codex"):
        args.no_codex = True
    apply_value(args, "ensemble", pack.get("ensemble"), "--ensemble")
    apply_value(args, "ensemble_passes", pack.get("ensemble_passes"), "--ensemble-passes")

    apply_value(args, "codex_model", models.get("codex_model"), "--codex-model")
    apply_value(args, "codex_budget", models.get("codex_budget"), "--codex-budget")
    apply_value(args, "local_model", models.get("local_model"), "--local-model")
    apply_value(args, "ensemble", models.get("ensemble"), "--ensemble")
    apply_value(args, "ensemble_passes", models.get("ensemble_passes"), "--ensemble-passes")

    if runtime.get("enabled") is True and not cli_flag_present("--runtime"):
        args.runtime = True
    apply_value(args, "zap_target", runtime.get("zap_target"), "--zap-target")
    apply_value(args, "odoomap_target", runtime.get("odoomap_target"), "--odoomap-target")
    apply_value(args, "odoo_version", odoo.get("version"), "--odoo-version")
    modules_value = review.get("modules")
    if isinstance(modules_value, list):
        modules_value = ",".join(str(item) for item in modules_value)
    apply_value(args, "modules", modules_value, "--modules")
    apply_value(args, "scope", review.get("scope"), "--scope")
    if review.get("quick") is True and not cli_flag_present("--quick"):
        args.quick = True
    if review.get("no_scans") is True and not cli_flag_present("--no-scans"):
        args.no_scans = True
    apply_value(args, "breadth_budget", review.get("breadth_budget"), "--breadth-budget")
    apply_value(args, "breadth_max_chunks", review.get("breadth_max_chunks"), "--breadth-max-chunks")
    if args.codex_budget not in {"low", "normal", "deep"}:
        warnings.append(f"{path}: invalid codex_budget {args.codex_budget!r}; using normal.")
        args.codex_budget = "normal"
    if args.ensemble not in {"off", "cheap", "balanced"}:
        warnings.append(f"{path}: invalid ensemble {args.ensemble!r}; using off.")
        args.ensemble = "off"
    if args.breadth_budget not in {"off", "low", "normal", "deep"}:
        warnings.append(f"{path}: invalid breadth_budget {args.breadth_budget!r}; using normal.")
        args.breadth_budget = "normal"
    return config, path, warnings


def rel(path: Path, root: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def should_skip(path: Path) -> bool:
    parts = set(path.parts)
    if parts & {".git", ".hg", ".svn", ".audit", "__pycache__", ".venv", "venv", "node_modules", ".worktrees"}:
        return True
    return any(part.startswith(".audit-") and part not in {".audit-accepted-risks.yml", ".audit-accepted-risks.yaml", ".audit-accepted-risks.json", ".audit-fix-list.yml", ".audit-fix-list.yaml", ".audit-fix-list.json", ".audit-baseline"} for part in path.parts)


def which(name: str) -> str | None:
    return shutil.which(name)


def run(cmd: list[str], cwd: Path, log_path: Path, stdout_path: Path | None = None, timeout: int = 1800) -> dict:
    started = dt.datetime.now(dt.timezone.utc).isoformat()
    record = {"started": started, "cmd": cmd, "cwd": str(cwd)}
    label = cmd[0] if cmd else "command"
    progress(f"start {label}: {' '.join(cmd[:4])}{' ...' if len(cmd) > 4 else ''}")
    with log_path.open("a", encoding="utf-8") as log:
        log.write("$ " + " ".join(cmd) + "\n")
    try:
        completed = subprocess.run(
            cmd,
            cwd=str(cwd),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
        )
        output = clean_output(completed.stdout or "")
        if stdout_path:
            stdout_path.parent.mkdir(parents=True, exist_ok=True)
            stdout_path.write_text(output, encoding="utf-8", errors="replace")
        with log_path.open("a", encoding="utf-8") as log:
            log.write(output[-12000:])
            log.write(f"\n[exit {completed.returncode}]\n\n")
        record.update({"returncode": completed.returncode, "output": str(stdout_path) if stdout_path else output[-2000:]})
        progress(f"done {label}: exit {completed.returncode}")
    except subprocess.TimeoutExpired:
        with log_path.open("a", encoding="utf-8") as log:
            log.write(f"\n[TIMEOUT after {timeout}s]\n\n")
        record.update({"returncode": 124, "error": f"timeout after {timeout}s"})
        progress(f"timeout {label}: after {timeout}s")
    except Exception as exc:  # noqa: BLE001
        with log_path.open("a", encoding="utf-8") as log:
            log.write(f"\n[ERROR {exc}]\n\n")
        record.update({"returncode": 1, "error": str(exc)})
        progress(f"error {label}: {exc}")
    record["finished"] = dt.datetime.now(dt.timezone.utc).isoformat()
    return record


def parse_scope_yaml(path: Path) -> dict:
    """Minimal YAML reader for scope.yml — supports `key: value`, lists with `- `, and nested dicts via 2-space indent.

    Schema:
        version: "1.0"
        accepted_risks:
          - id: AR-001
            module: portal              # optional
            file: addons/portal/main.py # optional
            rule: csrf_state_change_get # optional (matches CWE map key)
            cwe: CWE-352                # optional
            line_range: [100, 200]      # optional
            reason: "Customer accepted ..."
            expires: "2026-12-31"        # optional
        excluded_modules: [legacy_module]
        excluded_paths: ["addons/third_party/**"]
    """
    if not path.exists():
        return {}
    text = path.read_text(encoding="utf-8")
    return _parse_simple_yaml(text)


def _parse_simple_yaml(text: str) -> dict:
    """Tiny YAML subset: scalars, lists (- ), nested dicts via 2-space indent.

    Not a full YAML parser. Supports the subset needed for scope.yml.
    """
    root: dict = {}
    stack: list[tuple[int, object]] = [(-1, root)]
    pending_list_key: tuple[int, str] | None = None

    for raw_line in text.splitlines():
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        stripped = raw_line.rstrip()
        indent = len(stripped) - len(stripped.lstrip(" "))
        content = stripped.lstrip(" ")

        while stack and indent <= stack[-1][0] and len(stack) > 1:
            stack.pop()

        parent = stack[-1][1]

        if content.startswith("- "):
            item_text = content[2:]
            if not isinstance(parent, list):
                if pending_list_key is None:
                    raise ValueError(f"List item without parent list: {content!r}")
                outer_indent, list_key = pending_list_key
                outer = stack[-1][1]
                if isinstance(outer, dict):
                    new_list: list = []
                    outer[list_key] = new_list
                    stack.append((outer_indent, new_list))
                    parent = new_list
                    pending_list_key = None
                else:
                    raise ValueError(f"Cannot attach list to non-dict at {content!r}")
            if ":" in item_text and not item_text.endswith(":"):
                key, _, val = item_text.partition(":")
                obj = {key.strip(): _yaml_scalar(val.strip())}
                parent.append(obj)
                stack.append((indent, obj))
            elif item_text.endswith(":"):
                obj = {}
                parent.append(obj)
                stack.append((indent, obj))
            else:
                parent.append(_yaml_scalar(item_text))
            continue

        if content.endswith(":"):
            key = content[:-1].strip()
            if isinstance(parent, dict):
                parent[key] = None
                pending_list_key = (indent, key)
            continue

        if ":" in content:
            key, _, val = content.partition(":")
            key = key.strip()
            val = val.strip()
            if isinstance(parent, dict):
                parent[key] = _yaml_scalar(val)
                pending_list_key = None
    return root


def _yaml_scalar(value: str):
    if value == "":
        return None
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [_yaml_scalar(item.strip()) for item in inner.split(",")]
    if value.startswith('"') and value.endswith('"'):
        return value[1:-1]
    if value.startswith("'") and value.endswith("'"):
        return value[1:-1]
    if value.lower() in {"true", "yes"}:
        return True
    if value.lower() in {"false", "no"}:
        return False
    try:
        return int(value)
    except ValueError:
        try:
            return float(value)
        except ValueError:
            return value


def fetch_pr_files(pr_number: str, pr_repo: str | None, repo: Path) -> list[str]:
    """Return list of repo-relative file paths changed in the PR. Requires gh CLI."""
    if not which("gh"):
        return []
    cmd = ["gh", "pr", "view", pr_number, "--json", "files", "-q", ".files[].path"]
    if pr_repo:
        cmd.extend(["-R", pr_repo])
    try:
        proc = subprocess.run(cmd, cwd=repo, capture_output=True, text=True, timeout=60)
    except Exception:  # noqa: BLE001
        return []
    if proc.returncode != 0:
        return []
    return [line.strip() for line in proc.stdout.splitlines() if line.strip()]


def filter_manifests_by_pr_files(manifests: list[dict], pr_files: list[str]) -> list[dict]:
    """Keep only modules that own at least one PR file."""
    if not pr_files:
        return manifests
    keep: list[dict] = []
    for item in manifests:
        prefix = item["dir"].rstrip("/") + "/"
        if any(f.startswith(prefix) or f == item["path"] for f in pr_files):
            keep.append(item)
    return keep


def filter_manifests_by_scope(manifests: list[dict], scope: dict) -> list[dict]:
    excluded = set(scope.get("excluded_modules") or [])
    if not excluded:
        return manifests
    return [item for item in manifests if item["module"] not in excluded]


def parse_manifest(path: Path) -> dict:
    text = path.read_text(encoding="utf-8", errors="replace")
    try:
        data = ast.literal_eval(text)
        if not isinstance(data, dict):
            data = {}
    except Exception as exc:  # noqa: BLE001
        data = {"_parse_error": str(exc)}
    return data


def find_manifests(repo: Path, allowed_modules: set[str] | None) -> list[dict]:
    manifests = []
    for path in repo.rglob("__manifest__.py"):
        if should_skip(path):
            continue
        module = path.parent.name
        if allowed_modules and module not in allowed_modules:
            continue
        data = parse_manifest(path)
        manifests.append(
            {
                "module": module,
                "path": rel(path, repo),
                "dir": rel(path.parent, repo),
                "name": data.get("name"),
                "version": data.get("version"),
                "license": data.get("license"),
                "depends": data.get("depends", []),
                "data": data.get("data", []),
                "demo": data.get("demo", []),
                "external_dependencies": data.get("external_dependencies", {}),
                "installable": data.get("installable", True),
                "application": data.get("application", False),
                "parse_error": data.get("_parse_error"),
                "origin": "addon",
            }
        )
    return sorted(manifests, key=lambda item: item["module"])


LOOSE_PY_DIRS: dict[str, str] = {
    # subdir-relative-to-repo : origin-tag
    "docs/server_actions": "server_action",
    "scripts": "script",
}


def find_loose_python(repo: Path, args: argparse.Namespace) -> list[dict]:
    """Index loose Python files outside __manifest__.py addons.

    Treat each file as a pseudo-module so it flows through write_inventory,
    extract_routes, scan_patterns, and codex_prompt without special-casing.
    """
    pseudo: list[dict] = []
    skip_origins: set[str] = set()
    if args.no_server_actions:
        skip_origins.add("server_action")
    if args.no_scripts:
        skip_origins.add("script")
    for subdir, origin in LOOSE_PY_DIRS.items():
        if origin in skip_origins:
            continue
        base = repo / subdir
        if not base.exists() or not base.is_dir():
            continue
        for path in sorted(base.rglob("*.py")):
            if should_skip(path):
                continue
            module = f"{origin}:{path.stem}"
            pseudo.append(
                {
                    "module": module,
                    "path": rel(path, repo),
                    "dir": rel(path.parent, repo),
                    "name": f"{origin} {path.stem}",
                    "version": None,
                    "license": None,
                    "depends": [],
                    "data": [],
                    "demo": [],
                    "external_dependencies": {},
                    "installable": True,
                    "application": False,
                    "parse_error": None,
                    "origin": origin,
                    "_loose_file": rel(path, repo),
                }
            )
    return pseudo


ROUTE_RE = re.compile(
    r"@(?P<decorator>[A-Za-z_][A-Za-z0-9_]*(?:\.[A-Za-z_][A-Za-z0-9_]*){0,2})\((?P<args>.*?)\)",
    re.DOTALL,
)
KW_RE = re.compile(r"(?P<key>auth|csrf|type|methods)\s*=\s*(?P<value>[^,\)]*)")
HTTP_ROUTE_PARAM_RE = re.compile(r"<[^>]+>")


def extract_routes(repo: Path, manifests: list[dict]) -> list[dict]:
    routes = []
    for item in manifests:
        module = item["module"]
        loose_file = item.get("_loose_file")
        if loose_file:
            file_paths = [repo / loose_file]
        else:
            module_dir = repo / item["dir"]
            file_paths = list(module_dir.rglob("*.py"))
        for path in file_paths:
            if should_skip(path) or not path.exists() or path.is_dir():
                continue
            text = path.read_text(encoding="utf-8", errors="replace")
            try:
                tree = ast.parse(text)
            except SyntaxError:
                routes.extend(_regex_extract_routes(text, module, path, repo))
                continue
            visitor = _RouteExtractor(module, path, repo, _static_constants_from_body(tree.body))
            visitor.visit(tree)
            routes.extend(visitor.routes)
    return routes


def _regex_extract_routes(text: str, module: str, path: Path, repo: Path) -> list[dict]:
    """Fallback route extraction for syntactically invalid files."""
    routes = []
    route_decorator_names = _regex_route_decorator_names(text)
    for match in ROUTE_RE.finditer(text):
        if not _is_regex_route_decorator(match.group("decorator"), route_decorator_names):
            continue
        line = text.count("\n", 0, match.start()) + 1
        tail = text[match.end() : match.end() + 500]
        def_match = re.search(r"def\s+([A-Za-z_][A-Za-z0-9_]*)\s*\(", tail)
        kwargs = {m.group("key"): m.group("value").strip() for m in KW_RE.finditer(match.group("args"))}
        paths = extract_route_paths(match.group("args"))
        routes.append(
            {
                "module": module,
                "file": rel(path, repo),
                "line": line,
                "function": def_match.group(1) if def_match else None,
                "route_args": " ".join(match.group("args").split())[:500],
                "paths": paths,
                "auth": kwargs.get("auth", "user(default)"),
                "csrf": kwargs.get("csrf", "True(default)"),
                "type": kwargs.get("type", "http(default)"),
                "methods": kwargs.get("methods"),
            }
        )
    return routes


def _regex_route_decorator_names(text: str) -> set[str]:
    names = {"http.route", "odoo.http.route"}
    for clause in _regex_import_clauses(text, "odoo"):
        for part in clause.split(","):
            tokens = part.strip().split()
            if not tokens or tokens[0] != "http":
                continue
            names.add(f"{tokens[2]}.route" if len(tokens) >= 3 and tokens[1] == "as" else "http.route")
    for match in re.finditer(r"import\s+odoo\.http(?:\s+as\s+([A-Za-z_][A-Za-z0-9_]*))?", text):
        alias = match.group(1)
        names.add(f"{alias}.route" if alias else "odoo.http.route")
    for clause in _regex_import_clauses(text, "odoo.http"):
        for part in clause.split(","):
            tokens = part.strip().split()
            if not tokens or tokens[0] != "route":
                continue
            names.add(tokens[2] if len(tokens) >= 3 and tokens[1] == "as" else "route")
    return names


def _regex_import_clauses(text: str, module: str) -> list[str]:
    clauses: list[str] = []
    pattern = re.compile(
        rf"from\s+{re.escape(module)}\s+import\s+(?:\((?P<paren>.*?)\)|(?P<line>[^\n]+))",
        re.DOTALL,
    )
    for match in pattern.finditer(text):
        clause = match.group("paren") if match.group("paren") is not None else match.group("line")
        clauses.append(clause)
    return clauses


def _is_regex_route_decorator(decorator: str, route_decorator_names: set[str]) -> bool:
    return (
        decorator in route_decorator_names
        or re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*\.http\.route", decorator) is not None
        or re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*_http\.route", decorator) is not None
    )


class _RouteExtractor(ast.NodeVisitor):
    def __init__(self, module: str, path: Path, repo: Path, module_constants: dict[str, ast.AST]) -> None:
        self.module = module
        self.path = path
        self.repo = repo
        self.module_constants = module_constants
        self.class_constants_stack: list[dict[str, ast.AST]] = []
        self.http_module_names = {"http"}
        self.odoo_module_names = {"odoo"}
        self.route_decorator_names: set[str] = set()
        self.routes: list[dict] = []

    def visit_Import(self, node: ast.Import) -> None:
        for alias in node.names:
            if alias.name == "odoo":
                self.odoo_module_names.add(alias.asname or alias.name)
            elif alias.name == "odoo.http" and alias.asname:
                self.http_module_names.add(alias.asname)
        self.generic_visit(node)

    def visit_ImportFrom(self, node: ast.ImportFrom) -> None:
        if node.module == "odoo":
            for alias in node.names:
                if alias.name == "http":
                    self.http_module_names.add(alias.asname or alias.name)
        elif node.module == "odoo.http":
            for alias in node.names:
                if alias.name == "route":
                    self.route_decorator_names.add(alias.asname or alias.name)
        self.generic_visit(node)

    def visit_ClassDef(self, node: ast.ClassDef) -> None:
        self.class_constants_stack.append(_static_constants_from_body(node.body))
        self.generic_visit(node)
        self.class_constants_stack.pop()

    def visit_FunctionDef(self, node: ast.FunctionDef) -> None:
        self._visit_function(node)
        self.generic_visit(node)

    def visit_AsyncFunctionDef(self, node: ast.AsyncFunctionDef) -> None:
        self._visit_function(node)
        self.generic_visit(node)

    def _visit_function(self, node: ast.FunctionDef | ast.AsyncFunctionDef) -> None:
        constants = self._effective_constants()
        for decorator in node.decorator_list:
            if not self._is_http_route(decorator):
                continue
            kwargs = _route_kwargs_from_decorator(decorator, constants)
            self.routes.append(
                {
                    "module": self.module,
                    "file": rel(self.path, self.repo),
                    "line": getattr(decorator, "lineno", node.lineno),
                    "function": node.name,
                    "route_args": _route_args_text(decorator, constants),
                    "paths": _route_paths_from_decorator(decorator, constants),
                    "auth": kwargs.get("auth", "user(default)"),
                    "csrf": kwargs.get("csrf", "True(default)"),
                    "type": kwargs.get("type", "http(default)"),
                    "methods": kwargs.get("methods"),
                }
            )

    def _is_http_route(self, node: ast.AST) -> bool:
        target = node.func if isinstance(node, ast.Call) else node
        if isinstance(target, ast.Attribute):
            return target.attr == "route" and self._is_odoo_http_expr(target.value)
        if isinstance(target, ast.Name):
            return target.id in self.route_decorator_names
        return False

    def _is_odoo_http_expr(self, node: ast.AST) -> bool:
        if isinstance(node, ast.Name):
            return node.id in self.http_module_names
        return (
            isinstance(node, ast.Attribute)
            and node.attr == "http"
            and isinstance(node.value, ast.Name)
            and node.value.id in self.odoo_module_names
        )

    def _effective_constants(self) -> dict[str, ast.AST]:
        if not self.class_constants_stack:
            return self.module_constants
        constants = dict(self.module_constants)
        for class_constants in self.class_constants_stack:
            constants.update(class_constants)
        return constants


def _route_args_text(node: ast.AST, constants: dict[str, ast.AST]) -> str:
    if not isinstance(node, ast.Call):
        return ""
    parts = [ast.unparse(_resolve_constant(arg, constants)) for arg in node.args]
    for keyword in node.keywords:
        if keyword.arg is None:
            parts.append(f"**{ast.unparse(_resolve_constant(keyword.value, constants))}")
        else:
            parts.append(f"{keyword.arg}={ast.unparse(_resolve_constant(keyword.value, constants))}")
    return " ".join(" ".join(parts).split())[:500]


def _route_kwargs_from_decorator(node: ast.AST, constants: dict[str, ast.AST]) -> dict[str, str]:
    kwargs: dict[str, str] = {}
    if not isinstance(node, ast.Call):
        return kwargs
    for keyword in node.keywords:
        if keyword.arg in {"auth", "csrf", "type", "methods"}:
            kwargs[keyword.arg] = ast.unparse(_resolve_constant(keyword.value, constants))
        elif keyword.arg is None:
            expanded = _static_dict_items(_resolve_constant(keyword.value, constants), constants)
            for key, value in expanded.items():
                if key in {"auth", "csrf", "type", "methods"}:
                    kwargs[key] = ast.unparse(_resolve_constant(value, constants))
    return kwargs


def _route_paths_from_decorator(node: ast.AST, constants: dict[str, ast.AST]) -> list[str]:
    if not isinstance(node, ast.Call):
        return []
    candidates = list(node.args[:1])
    for keyword in node.keywords:
        if keyword.arg in {"route", "routes"}:
            candidates.append(keyword.value)
        elif keyword.arg is None:
            expanded = _static_dict_items(_resolve_constant(keyword.value, constants), constants)
            for key in ("route", "routes"):
                if key in expanded:
                    candidates.append(expanded[key])
    values: list[str] = []
    for candidate in candidates:
        values.extend(_literal_route_values(candidate, constants))
    return values


def _literal_route_values(node: ast.AST, constants: dict[str, ast.AST]) -> list[str]:
    node = _resolve_constant(node, constants)
    if isinstance(node, ast.Constant) and isinstance(node.value, str):
        return [node.value]
    if isinstance(node, ast.List | ast.Tuple | ast.Set):
        values = []
        for item in node.elts:
            resolved = _resolve_constant(item, constants)
            if isinstance(resolved, ast.Constant) and isinstance(resolved.value, str):
                values.append(resolved.value)
        return values
    return []


def _static_dict_items(node: ast.AST, constants: dict[str, ast.AST]) -> dict[str, ast.AST]:
    node = _resolve_constant(node, constants)
    if not isinstance(node, ast.Dict):
        return {}
    values: dict[str, ast.AST] = {}
    for key, value in zip(node.keys, node.values, strict=False):
        if key is None:
            continue
        resolved_key = _resolve_constant(key, constants)
        if isinstance(resolved_key, ast.Constant) and isinstance(resolved_key.value, str):
            values[resolved_key.value] = value
    return values


def _static_constants_from_body(statements: list[ast.stmt]) -> dict[str, ast.AST]:
    constants: dict[str, ast.AST] = {}
    for statement in statements:
        if isinstance(statement, ast.Assign):
            for target in statement.targets:
                if isinstance(target, ast.Name) and _is_static_literal(statement.value):
                    constants[target.id] = statement.value
        elif (
            isinstance(statement, ast.AnnAssign)
            and isinstance(statement.target, ast.Name)
            and statement.value is not None
            and _is_static_literal(statement.value)
        ):
            constants[statement.target.id] = statement.value
    return constants


def _is_static_literal(node: ast.AST) -> bool:
    if isinstance(node, ast.Constant):
        return True
    if isinstance(node, ast.Name):
        return True
    if isinstance(node, ast.List | ast.Tuple | ast.Set):
        return all(_is_static_literal(item) for item in node.elts)
    if isinstance(node, ast.Dict):
        return all(
            key is not None and _is_static_literal(key) and _is_static_literal(value)
            for key, value in zip(node.keys, node.values, strict=False)
        )
    return False


def _resolve_constant(node: ast.AST, constants: dict[str, ast.AST], seen: set[str] | None = None) -> ast.AST:
    if seen is None:
        seen = set()
    if isinstance(node, ast.Name) and node.id in constants and node.id not in seen:
        return _resolve_constant(constants[node.id], constants, seen | {node.id})
    return node


def extract_route_paths(args_text: str) -> list[str]:
    """Best-effort extraction of literal route paths from @http.route(...)."""
    try:
        node = ast.parse(f"_route({args_text})", mode="eval")
    except SyntaxError:
        return []
    if not isinstance(node.body, ast.Call):
        return []
    values: list[str] = []
    candidates = []
    if node.body.args:
        candidates.append(node.body.args[0])
    for keyword in node.body.keywords:
        if keyword.arg in {"route", "routes"}:
            candidates.append(keyword.value)
    for candidate in candidates:
        if isinstance(candidate, ast.Constant) and isinstance(candidate.value, str):
            values.append(candidate.value)
        elif isinstance(candidate, (ast.List, ast.Tuple)):
            for item in candidate.elts:
                if isinstance(item, ast.Constant) and isinstance(item.value, str):
                    values.append(item.value)
    return values


def index_acl(repo: Path, manifests: list[dict]) -> list[dict]:
    rows = []
    for item in manifests:
        module_dir = repo / item["dir"]
        for path in module_dir.rglob("ir.model.access.csv"):
            if should_skip(path):
                continue
            try:
                with path.open(newline="", encoding="utf-8", errors="replace") as handle:
                    for row in csv.DictReader(handle):
                        row["_module"] = item["module"]
                        row["_file"] = rel(path, repo)
                        rows.append(row)
            except Exception as exc:  # noqa: BLE001
                rows.append({"_module": item["module"], "_file": rel(path, repo), "_error": str(exc)})
    return rows


SHARP_EDGE_PATTERNS = {
    "sudo": r"\.sudo\(",
    "with_user": r"\.with_user\(",
    "with_context": r"\.with_context\(",
    "raw_sql": r"\.cr\.execute\(|\bcr\.execute\(",
    "request_params": r"request\.params|request\.jsonrequest",
    "safe_eval": r"\bsafe_eval\(",
    "t_raw": r"t-raw\s*=",
    "markup": r"\bMarkup\(",
    "attachments": r"ir\.attachment|public\s*=\s*True",
}


SHARP_EDGE_WEIGHTS = {
    "sudo": 3,
    "with_user": 2,
    "with_context": 1,
    "raw_sql": 4,
    "request_params": 2,
    "safe_eval": 5,
    "t_raw": 4,
    "markup": 2,
    "attachments": 1,
}


def scan_patterns(repo: Path, manifests: list[dict]) -> dict:
    compiled = {key: re.compile(value) for key, value in SHARP_EDGE_PATTERNS.items()}
    counts = dict.fromkeys(SHARP_EDGE_PATTERNS, 0)
    hits: dict[str, list[dict]] = {key: [] for key in SHARP_EDGE_PATTERNS}
    per_module: dict[str, dict[str, int]] = {item["module"]: dict.fromkeys(SHARP_EDGE_PATTERNS, 0) for item in manifests}
    for item in manifests:
        module = item["module"]
        loose_file = item.get("_loose_file")
        if loose_file:
            file_paths = [repo / loose_file]
        else:
            module_dir = repo / item["dir"]
            file_paths = list(module_dir.rglob("*"))
        for path in file_paths:
            if should_skip(path) or path.is_dir() or path.suffix not in {".py", ".xml", ".csv"}:
                continue
            text = path.read_text(encoding="utf-8", errors="replace")
            for key, regex in compiled.items():
                matches = list(regex.finditer(text))
                if not matches:
                    continue
                counts[key] += len(matches)
                per_module[module][key] += len(matches)
                for match in matches[:20]:
                    hits[key].append({
                        "module": module,
                        "file": rel(path, repo),
                        "line": text.count("\n", 0, match.start()) + 1,
                    })
    return {"counts": counts, "sample_hits": hits, "per_module": per_module}


def compute_module_risk(manifests: list[dict], routes: list[dict], acl_rows: list[dict], pattern_summary: dict) -> list[dict]:
    """Heuristic risk score per module. Higher = audit first."""
    routes_by_module: dict[str, int] = {}
    public_by_module: dict[str, int] = {}
    for r in routes:
        routes_by_module[r["module"]] = routes_by_module.get(r["module"], 0) + 1
        auth = (r.get("auth") or "").lower()
        if "public" in auth or "none" in auth:
            public_by_module[r["module"]] = public_by_module.get(r["module"], 0) + 1
    acl_by_module: dict[str, int] = {}
    acl_global_by_module: dict[str, int] = {}
    for row in acl_rows:
        mod = row.get("_module") or ""
        if not mod:
            continue
        acl_by_module[mod] = acl_by_module.get(mod, 0) + 1
        if not (row.get("group_id:id") or row.get("group_id") or "").strip():
            acl_global_by_module[mod] = acl_global_by_module.get(mod, 0) + 1
    per_module = pattern_summary.get("per_module", {})

    rows: list[dict] = []
    for item in manifests:
        module = item["module"]
        route_count = routes_by_module.get(module, 0)
        public_count = public_by_module.get(module, 0)
        acl_count = acl_by_module.get(module, 0)
        acl_global = acl_global_by_module.get(module, 0)
        sharp = per_module.get(module, {})
        sharp_score = sum(sharp.get(k, 0) * SHARP_EDGE_WEIGHTS.get(k, 1) for k in SHARP_EDGE_PATTERNS)
        score = route_count * 1 + public_count * 5 + acl_global * 3 + sharp_score
        band = "low"
        if score >= 50:
            band = "critical"
        elif score >= 25:
            band = "high"
        elif score >= 10:
            band = "medium"
        rows.append({
            "module": module,
            "score": score,
            "band": band,
            "routes": route_count,
            "public_routes": public_count,
            "acl_rows": acl_count,
            "acl_global_rows": acl_global,
            "sharp_edge_score": sharp_score,
            "sharp_edges": sharp,
        })
    rows.sort(key=lambda r: (-r["score"], r["module"]))
    return rows


def write_scope_artifact(out: Path, scope_data: dict, args: argparse.Namespace, pr_files: list[str]) -> None:
    """Persist scope context for export/diff consumers and Phase 7 suppression."""
    inv = out / "inventory"
    inv.mkdir(parents=True, exist_ok=True)
    payload = {
        "scope_file": args.scope,
        "scope_data": scope_data,
        "pr": args.pr,
        "pr_repo": args.pr_repo,
        "pr_files": pr_files,
    }
    (inv / "scope.json").write_text(json.dumps(payload, indent=2), encoding="utf-8")


def copy_cwe_map(out: Path) -> None:
    """Copy CWE/CAPEC bug-shape map to inventory/ for hunter and Phase 7 use."""
    if not CWE_MAP_SRC.exists():
        return
    inv = out / "inventory"
    inv.mkdir(parents=True, exist_ok=True)
    shutil.copy2(CWE_MAP_SRC, inv / "cwe-map.json")


def write_module_risk(out: Path, risk_rows: list[dict]) -> None:
    inv = out / "inventory"
    inv.mkdir(parents=True, exist_ok=True)
    (inv / "module-risk.json").write_text(json.dumps(risk_rows, indent=2), encoding="utf-8")

    lines = [
        "# Module Risk Score",
        "",
        "Heuristic-only ranking to focus audit attention. Higher = read first.",
        "Score = routes + 5×public_routes + 3×ACL global rows + Σ(sharp_edge × weight).",
        "Bands: critical ≥50, high 25-49, medium 10-24, low <10. Not a finding list — Phase 7 still decides exploitability.",
        "",
        "| Module | Band | Score | Routes | Public | ACL Global | Sharp Edge |",
        "| --- | --- | ---: | ---: | ---: | ---: | ---: |",
    ]
    for r in risk_rows:
        lines.append(
            f"| `{r['module']}` | {r['band']} | {r['score']} | {r['routes']} | {r['public_routes']} | "
            f"{r['acl_global_rows']} | {r['sharp_edge_score']} |"
        )
    lines.append("")
    (out / "module-risk.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def _load_accepted_risks_file(path: Path) -> object:
    text = path.read_text(encoding="utf-8")
    if path.suffix == ".json":
        return json.loads(text)
    try:
        import yaml  # noqa: PLC0415
    except ImportError as exc:
        raise RuntimeError(
            f"Cannot read {path.name}: pyyaml is not installed. "
            "Install pyyaml or convert the file to .json format."
        ) from exc
    return yaml.safe_load(text)


def _validate_accepted_risks(data: object, source: Path) -> tuple[list[dict], list[str]]:
    errors: list[str] = []
    if not isinstance(data, dict):
        return [], [f"{source.name}: top-level must be a mapping with `version` and `risks`."]
    if data.get("version") != 1:
        errors.append(f"{source.name}: top-level `version` must equal 1.")
    risks = data.get("risks", [])
    if not isinstance(risks, list):
        errors.append(f"{source.name}: `risks` must be a list.")
        return [], errors
    seen_ids: set[str] = set()
    today = dt.date.today()
    cleaned: list[dict] = []
    for index, entry in enumerate(risks):
        prefix = f"{source.name}#{index}"
        if not isinstance(entry, dict):
            errors.append(f"{prefix}: entry must be a mapping.")
            continue
        for field in ACCEPTED_RISKS_REQUIRED:
            value = entry.get(field)
            if value is None or (isinstance(value, str) and not value.strip()):
                errors.append(f"{prefix}: `{field}` is required.")
        entry_id = entry.get("id")
        if entry_id in seen_ids:
            errors.append(f"{prefix}: duplicate id `{entry_id}`.")
        elif entry_id:
            seen_ids.add(entry_id)
        accepted_date = expires_date = None
        try:
            accepted_date = dt.date.fromisoformat(str(entry.get("accepted", "")))
        except ValueError:
            errors.append(f"{prefix}: `accepted` must be YYYY-MM-DD.")
        try:
            expires_date = dt.date.fromisoformat(str(entry.get("expires", "")))
        except ValueError:
            errors.append(f"{prefix}: `expires` must be YYYY-MM-DD.")
        if accepted_date and accepted_date > today:
            errors.append(f"{prefix}: `accepted` is in the future.")
        if accepted_date and expires_date and accepted_date > expires_date:
            errors.append(f"{prefix}: `accepted` is after `expires`.")
        pattern_kind = entry.get("pattern_kind", "literal")
        if pattern_kind not in ("literal", "regex"):
            errors.append(f"{prefix}: `pattern_kind` must be 'literal' or 'regex'.")
        match_value = entry.get("match")
        if pattern_kind == "regex" and match_value:
            try:
                re.compile(match_value)
            except re.error as exc:
                errors.append(f"{prefix}: `match` regex does not compile: {exc}")
        lines = entry.get("lines")
        lines_ok = (
            lines is None
            or isinstance(lines, int)
            or (
                isinstance(lines, list)
                and len(lines) == 2
                and all(isinstance(coord, int) for coord in lines)
            )
        )
        if not lines_ok:
            errors.append(f"{prefix}: `lines` must be an int or [start, end] of ints.")
        cleaned.append(
            {
                **entry,
                "_accepted_date": accepted_date,
                "_expires_date": expires_date,
                "_pattern_kind": pattern_kind,
            }
        )
    return cleaned, errors


def _is_stale(entry: dict, repo: Path) -> bool:
    pattern = str(entry.get("file") or "")
    if not pattern:
        return True
    if any(ch in pattern for ch in "*?["):
        for path in repo.rglob("*"):
            if should_skip(path):
                continue
            if fnmatch.fnmatch(rel(path, repo), pattern):
                return False
        return True
    return not (repo / pattern).exists()


def load_accepted_risks(args: argparse.Namespace, repo: Path) -> dict:
    candidates: list[Path] = []
    if args.accepted_risks:
        candidates.append(Path(args.accepted_risks).expanduser().resolve())
    else:
        candidates.extend(repo / name for name in ACCEPTED_RISKS_FILES)
    chosen: Path | None = next((path for path in candidates if path.exists()), None)
    inventory = {
        "version": 1,
        "loaded_from": "none" if not chosen else (rel(chosen, repo) if chosen.is_relative_to(repo) else str(chosen)),
        "loaded_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "active": [],
        "expired": [],
        "stale": [],
        "errors": [],
    }
    if not chosen:
        return inventory
    try:
        data = _load_accepted_risks_file(chosen)
    except (RuntimeError, json.JSONDecodeError, ValueError) as exc:
        inventory["errors"].append(f"{chosen.name}: failed to parse: {exc}")
        return inventory
    cleaned, errors = _validate_accepted_risks(data or {}, chosen)
    inventory["errors"].extend(errors)
    today = dt.date.today()
    for entry in cleaned:
        expires = entry.get("_expires_date")
        days_remaining = (expires - today).days if expires else None
        record = {
            "id": entry.get("id"),
            "title": entry.get("title"),
            "file": entry.get("file"),
            "lines": entry.get("lines"),
            "match": entry.get("match"),
            "pattern_kind": entry.get("_pattern_kind", "literal"),
            "fingerprint": entry.get("fingerprint"),
            "reason": entry.get("reason"),
            "owner": entry.get("owner"),
            "accepted": str(entry.get("accepted", "")),
            "expires": str(entry.get("expires", "")),
            "severity_was": entry.get("severity_was"),
            "references": entry.get("references"),
            "days_remaining": days_remaining,
        }
        if expires and expires < today:
            inventory["expired"].append(record)
        elif _is_stale(entry, repo):
            inventory["stale"].append(record)
        else:
            inventory["active"].append(record)
    return inventory


def _load_fix_list_file(path: Path) -> object:
    text = path.read_text(encoding="utf-8")
    if path.suffix == ".json":
        return json.loads(text)
    try:
        import yaml  # noqa: PLC0415
    except ImportError as exc:
        raise RuntimeError(
            f"Cannot read {path.name}: pyyaml is not installed. "
            "Install pyyaml or convert the file to .json format."
        ) from exc
    return yaml.safe_load(text)


def _validate_fix_list(data: object, source: Path) -> tuple[list[dict], list[str]]:
    errors: list[str] = []
    if not isinstance(data, dict):
        return [], [f"{source.name}: top-level must be a mapping with `version` and `fixes`."]
    if data.get("version") != 1:
        errors.append(f"{source.name}: top-level `version` must equal 1.")
    fixes = data.get("fixes", [])
    if not isinstance(fixes, list):
        errors.append(f"{source.name}: `fixes` must be a list.")
        return [], errors
    seen_ids: set[str] = set()
    cleaned: list[dict] = []
    for index, entry in enumerate(fixes):
        prefix = f"{source.name}#{index}"
        if not isinstance(entry, dict):
            errors.append(f"{prefix}: entry must be a mapping.")
            continue
        for field in FIX_LIST_REQUIRED:
            value = entry.get(field)
            if value is None or (isinstance(value, str) and not value.strip()):
                errors.append(f"{prefix}: `{field}` is required.")
        entry_id = entry.get("id")
        if entry_id in seen_ids:
            errors.append(f"{prefix}: duplicate id `{entry_id}`.")
        elif entry_id:
            seen_ids.add(entry_id)
        status = entry.get("status")
        if status and status not in FIX_LIST_STATUSES:
            errors.append(
                f"{prefix}: `status` must be one of {FIX_LIST_STATUSES}; got `{status}`."
            )
        severity = entry.get("severity")
        if severity and severity not in FIX_LIST_SEVERITIES:
            errors.append(
                f"{prefix}: `severity` must be one of {FIX_LIST_SEVERITIES}; got `{severity}`."
            )
        target_date = fixed_at = None
        if entry.get("target_date") is not None:
            try:
                target_date = dt.date.fromisoformat(str(entry["target_date"]))
            except ValueError:
                errors.append(f"{prefix}: `target_date` must be YYYY-MM-DD.")
        if entry.get("fixed_at") is not None:
            try:
                fixed_at = dt.date.fromisoformat(str(entry["fixed_at"]))
            except ValueError:
                errors.append(f"{prefix}: `fixed_at` must be YYYY-MM-DD.")
        fingerprint = entry.get("fingerprint")
        if fingerprint and not re.fullmatch(r"[0-9a-f]{16}", str(fingerprint)):
            errors.append(f"{prefix}: `fingerprint` must match ^[0-9a-f]{{16}}$.")
        if not fingerprint and not entry.get("file"):
            errors.append(f"{prefix}: at least one of `fingerprint` or `file` is required.")
        if status == "wontfix":
            notes = entry.get("notes")
            if not notes or (isinstance(notes, str) and not notes.strip()):
                errors.append(f"{prefix}: `wontfix` entries require non-empty `notes`.")
        lines = entry.get("lines")
        lines_ok = (
            lines is None
            or isinstance(lines, int)
            or (
                isinstance(lines, list)
                and len(lines) == 2
                and all(isinstance(coord, int) for coord in lines)
            )
        )
        if not lines_ok:
            errors.append(f"{prefix}: `lines` must be an int or [start, end] of ints.")
        cleaned.append(
            {
                **entry,
                "_target_date": target_date,
                "_fixed_at": fixed_at,
            }
        )
    return cleaned, errors


def load_fix_list(args: argparse.Namespace, repo: Path) -> dict:
    candidates: list[Path] = []
    if args.fix_list:
        candidates.append(Path(args.fix_list).expanduser().resolve())
    else:
        candidates.extend(repo / name for name in FIX_LIST_FILES)
    chosen: Path | None = next((path for path in candidates if path.exists()), None)
    inventory = {
        "version": 1,
        "loaded_from": "none" if not chosen else (rel(chosen, repo) if chosen.is_relative_to(repo) else str(chosen)),
        "loaded_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "active": [],
        "overdue": [],
        "errors": [],
    }
    if not chosen:
        return inventory
    try:
        data = _load_fix_list_file(chosen)
    except (RuntimeError, json.JSONDecodeError, ValueError) as exc:
        inventory["errors"].append(f"{chosen.name}: failed to parse: {exc}")
        return inventory
    cleaned, errors = _validate_fix_list(data or {}, chosen)
    inventory["errors"].extend(errors)
    today = dt.date.today()
    for entry in cleaned:
        target_date = entry.get("_target_date")
        days_to_target = (target_date - today).days if target_date else None
        record = {
            "id": entry.get("id"),
            "fingerprint": entry.get("fingerprint"),
            "title": entry.get("title"),
            "file": entry.get("file"),
            "lines": entry.get("lines"),
            "severity": entry.get("severity"),
            "sink_kind": entry.get("sink_kind"),
            "owner": entry.get("owner"),
            "status": entry.get("status"),
            "target_date": str(entry["target_date"]) if entry.get("target_date") else None,
            "fixed_at": str(entry["fixed_at"]) if entry.get("fixed_at") else None,
            "notes": entry.get("notes"),
            "references": entry.get("references"),
            "days_to_target": days_to_target,
        }
        inventory["active"].append(record)
        if (
            entry.get("status") in ("open", "in-progress")
            and target_date
            and target_date < today
        ):
            inventory["overdue"].append(record)
    return inventory


def write_fix_list_artifacts(out: Path, inventory: dict) -> None:
    inv_dir = out / "inventory"
    inv_dir.mkdir(parents=True, exist_ok=True)
    (inv_dir / "fix-list.json").write_text(json.dumps(inventory, indent=2), encoding="utf-8")

    lines = ["# Fix-It List (Phase 0 — pre-reconciliation snapshot)", ""]
    lines.append(f"Loaded from: `{inventory.get('loaded_from')}`")
    lines.append(f"Loaded at: `{inventory.get('loaded_at')}`")
    lines.append("")
    lines.append(f"- Active entries: **{len(inventory['active'])}**")
    lines.append(f"- Overdue (open/in-progress past `target_date`): **{len(inventory['overdue'])}**")
    lines.append("")
    lines.append(
        "Phase 8 reconciliation against current-run findings produces the final "
        "REGRESSION / TRACKED / CONFIRMED-FIXED / WONTFIX / DRIFTED report. "
        "This Phase 0 snapshot only validates the file and lists overdue entries."
    )
    if inventory["errors"]:
        lines.append("")
        lines.append("## Errors — run aborted unless fix-list file is fixed")
        lines.append("")
        for err in inventory["errors"]:
            lines.append(f"- {err}")
    sections = (
        ("Overdue (open / in-progress past target_date)", inventory["overdue"]),
        ("Active", inventory["active"]),
    )
    for header, bucket in sections:
        if not bucket:
            continue
        lines.append("")
        lines.append(f"## {header}")
        lines.append("")
        lines.append("| ID | Status | Severity | Title | File | Lines | Owner | Target | Days |")
        lines.append("| --- | --- | --- | --- | --- | --- | --- | --- | ---: |")
        for entry in bucket:
            lns = entry.get("lines")
            if isinstance(lns, list):
                lns_str = f"{lns[0]}-{lns[1]}"
            elif lns is not None:
                lns_str = str(lns)
            else:
                lns_str = "—"
            target = entry.get("target_date") or "—"
            days = entry.get("days_to_target")
            days_str = "—" if days is None else str(days)
            lines.append(
                f"| `{entry.get('id')}` | {entry.get('status')} | {entry.get('severity')} | "
                f"{entry.get('title')} | `{entry.get('file')}` | {lns_str} | "
                f"{entry.get('owner')} | {target} | {days_str} |"
            )
    (out / "00-fix-list.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def write_accepted_risks_artifacts(out: Path, inventory: dict) -> None:
    inv_dir = out / "inventory"
    inv_dir.mkdir(parents=True, exist_ok=True)
    (inv_dir / "accepted-risks.json").write_text(json.dumps(inventory, indent=2), encoding="utf-8")

    lines = ["# Accepted Risks (Phase 0)", ""]
    lines.append(f"Loaded from: `{inventory.get('loaded_from')}`")
    lines.append(f"Loaded at: `{inventory.get('loaded_at')}`")
    lines.append("")
    lines.append(f"- Active: **{len(inventory['active'])}**")
    lines.append(f"- Expired (re-review needed): **{len(inventory['expired'])}**")
    lines.append(f"- Stale (file/glob matched nothing): **{len(inventory['stale'])}**")
    if inventory["errors"]:
        lines.append("")
        lines.append("## Errors — run aborted unless suppression file is fixed")
        lines.append("")
        for err in inventory["errors"]:
            lines.append(f"- {err}")
    sections = (
        ("Active", inventory["active"]),
        ("Expired (re-review)", inventory["expired"]),
        ("Stale (file/pattern not found in repo)", inventory["stale"]),
    )
    for header, bucket in sections:
        if not bucket:
            continue
        lines.append("")
        lines.append(f"## {header}")
        lines.append("")
        lines.append("| ID | Title | File | Lines | Owner | Expires | Days |")
        lines.append("| --- | --- | --- | --- | --- | --- | ---: |")
        for entry in bucket:
            lns = entry.get("lines")
            if isinstance(lns, list):
                lns_str = f"{lns[0]}-{lns[1]}"
            elif lns is not None:
                lns_str = str(lns)
            else:
                lns_str = "—"
            days = entry.get("days_remaining")
            days_str = "—" if days is None else str(days)
            lines.append(
                f"| `{entry.get('id')}` | {entry.get('title')} | `{entry.get('file')}` | {lns_str} | {entry.get('owner')} | {entry.get('expires')} | {days_str} |"
            )
    (out / "00-accepted-risks.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def write_inventory(repo: Path, out: Path, manifests: list[dict], routes: list[dict], acl_rows: list[dict], pattern_summary: dict, args: argparse.Namespace) -> None:
    inv = out / "inventory"
    inv.mkdir(parents=True, exist_ok=True)
    (inv / "manifests.json").write_text(json.dumps(manifests, indent=2), encoding="utf-8")
    (inv / "routes.json").write_text(json.dumps(routes, indent=2), encoding="utf-8")
    (inv / "acl-index.json").write_text(json.dumps(acl_rows, indent=2), encoding="utf-8")
    (inv / "sharp-edge-index.json").write_text(json.dumps(pattern_summary, indent=2), encoding="utf-8")
    graph = {item["module"]: item.get("depends", []) for item in manifests}
    (inv / "depends-graph.json").write_text(json.dumps(graph, indent=2), encoding="utf-8")

    by_origin: dict[str, int] = {}
    for item in manifests:
        origin = item.get("origin") or "addon"
        by_origin[origin] = by_origin.get(origin, 0) + 1

    lines = ["# Phase 0 - Odoo Module Inventory", ""]
    lines.append(f"Target: `{repo}`")
    lines.append(f"Modules found: {len(manifests)}")
    for origin, count in sorted(by_origin.items()):
        lines.append(f"- `origin={origin}`: {count}")
    if args.modules:
        lines.append(f"Module filter: `{args.modules}`")
    lines.append("")
    lines.append("| Module | Origin | Name | Version | Depends | Manifest |")
    lines.append("| --- | --- | --- | --- | --- | --- |")
    for item in manifests:
        depends = ", ".join(item.get("depends") or [])
        origin = item.get("origin") or "addon"
        lines.append(f"| `{item['module']}` | {origin} | {item.get('name') or ''} | {item.get('version') or ''} | {depends} | `{item['path']}` |")
    (out / "00-modules.md").write_text("\n".join(lines) + "\n", encoding="utf-8")

    routes_by_module: dict[str, list[dict]] = {}
    for route in routes:
        routes_by_module.setdefault(route["module"], []).append(route)
    acl_by_module: dict[str, list[dict]] = {}
    for row in acl_rows:
        mod = row.get("_module")
        if mod:
            acl_by_module.setdefault(mod, []).append(row)
    py_files_by_module: dict[str, list[str]] = {}
    for item in manifests:
        module = item["module"]
        loose_file = item.get("_loose_file")
        if loose_file:
            py_files_by_module[module] = [loose_file]
            continue
        module_dir = repo / item["dir"]
        files = []
        for path in module_dir.rglob("*.py"):
            if should_skip(path) or path.is_dir():
                continue
            files.append(rel(path, repo))
        py_files_by_module[module] = sorted(files)

    (inv / "py-files-by-module.json").write_text(json.dumps(py_files_by_module, indent=2), encoding="utf-8")

    surface = ["# Phase 1 - Odoo Attack Surface Map", ""]
    surface.append(f"Odoo version override: `{args.odoo_version or 'not provided'}`")
    surface.append(f"Modules in scope: {len(manifests)}")
    surface.append(f"Routes found: {len(routes)}")
    surface.append(f"ACL rows found: {len(acl_rows)}")
    surface.append("")
    surface.append("## Route Summary by Auth")
    surface.append("")
    surface.append("| Auth | Count |")
    surface.append("| --- | ---: |")
    by_auth: dict[str, int] = {}
    for route in routes:
        by_auth[route["auth"]] = by_auth.get(route["auth"], 0) + 1
    for auth, count in sorted(by_auth.items()):
        surface.append(f"| `{auth}` | {count} |")
    surface.append("")
    surface.append("## Global Sharp-Edge Counts")
    surface.append("")
    surface.append("| Pattern | Count |")
    surface.append("| --- | ---: |")
    for key, count in sorted(pattern_summary["counts"].items()):
        surface.append(f"| `{key}` | {count} |")
    surface.append("")
    surface.append("## Per-Module Surface Index")
    surface.append("")
    surface.append("Every in-scope module gets a section. Hunters MUST cite at least one file:line per module under `Reviewed:` (REJECT cases included).")
    surface.append("")
    per_module_counts = pattern_summary.get("per_module", {})
    for item in manifests:
        module = item["module"]
        origin = item.get("origin") or "addon"
        surface.append(f"### `{module}`  (origin: {origin})")
        surface.append("")
        if item.get("name") or item.get("version"):
            surface.append(f"- **Name/Version:** {item.get('name') or '(no name)'} / {item.get('version') or '(no version)'}")
        depends = ", ".join(item.get("depends") or [])
        if depends:
            surface.append(f"- **Depends:** {depends}")
        py_files = py_files_by_module.get(module, [])
        surface.append(f"- **Python files:** {len(py_files)}")
        if py_files:
            sample = py_files[:8]
            surface.append("  - " + "\n  - ".join(f"`{p}`" for p in sample))
            if len(py_files) > 8:
                surface.append(f"  - … +{len(py_files) - 8} more")
        module_routes = routes_by_module.get(module, [])
        if module_routes:
            surface.append(f"- **HTTP routes:** {len(module_routes)}")
            for route in module_routes[:10]:
                surface.append(f"  - `{route['file']}:{route['line']}` `{route.get('function') or '?'}` auth=`{route.get('auth')}` csrf=`{route.get('csrf')}` type=`{route.get('type')}`")
            if len(module_routes) > 10:
                surface.append(f"  - … +{len(module_routes) - 10} more routes")
        else:
            surface.append("- **HTTP routes:** none")
        module_acl = acl_by_module.get(module, [])
        if module_acl:
            surface.append(f"- **ACL CSV rows:** {len(module_acl)}")
        counts = per_module_counts.get(module, {})
        flagged = {k: v for k, v in counts.items() if v}
        if flagged:
            counts_str = ", ".join(f"{k}={v}" for k, v in sorted(flagged.items()))
            surface.append(f"- **Sharp-edge hits:** {counts_str}")
        else:
            surface.append("- **Sharp-edge hits:** none")
        surface.append("")
    surface.append("This is a machine inventory, not a finding list. Phase 7 still decides exploitability.")
    (out / "01-attack-surface.md").write_text("\n".join(surface) + "\n", encoding="utf-8")


def write_goals_guide(repo: Path, out: Path, manifests: list[dict], routes: list[dict], args: argparse.Namespace) -> None:
    modules = len(manifests)
    route_count = len(routes)
    scope = f"modules {args.modules}" if args.modules else f"{modules} discovered Odoo module(s)"
    depth = "quick source review" if args.quick else "full source review"
    codex_lane = "disabled" if args.no_codex else f"enabled ({args.codex_model}, {args.codex_budget})"
    qwen_lane = "disabled" if args.no_local_qwen else f"enabled ({args.local_model})"
    lead_sources = ["inventory", "attack-surface map"]
    if not args.quick and not args.no_scans:
        lead_sources.append("scanner leads")
    if not args.no_codex:
        lead_sources.append("Codex hunter outputs")
    if not args.no_local_qwen:
        lead_sources.append("local Qwen hints")

    objective = (
        f"Complete an evidence-backed Odoo security review of {repo} covering {scope}, "
        f"{route_count} mapped route(s), {', '.join(lead_sources)}, 6-gate validation, "
        "and final client-ready findings."
    )

    lines = [
        "# Codex Goals Guide",
        "",
        "Use this file when the lead review session supports `/goals` or equivalent goal tracking.",
        "Goals are best used for the lead/orchestrator session, not for every short hunter subprocess.",
        "",
        "## Suggested Goal",
        "",
        "```text",
        objective,
        "```",
        "",
        "## Suggested Budget",
        "",
    ]
    if args.quick:
        lines.append("- `low` or a short explicit token budget: quick run, no scanner/discourse depth.")
    elif modules <= 5:
        lines.append("- `normal`: small repo, full validation still matters more than hunter breadth.")
    elif modules <= 30:
        lines.append("- `normal` to `deep`: medium repo; use `deep` when runtime evidence or requirements mode is in scope.")
    else:
        lines.append("- `deep`: large repo; consider scoping modules before spending review budget.")

    lines.extend(
        [
            "",
            "## Checkpoints",
            "",
            "- Phase 0/1 inventory complete: `00-modules.md`, `01-attack-surface.md`, and `inventory/*` exist.",
            "- Scanner/advisory leads complete: `scans/*`, `local-qwen/*`, and `tooling.md` record missing tools.",
            "- Phase 5 hunter drafts complete: `codex/hunters/*.md` or equivalent manual hunter notes exist.",
            "- Phase 5.5/6 correlation complete: discourse challenges resolved and chained paths drafted.",
            "- Phase 7 validation complete: every candidate has ACCEPT, DOWNGRADE, REJECT, or NEEDS-MANUAL with 6-gate reasoning.",
            "- Phase 8 output complete: final report, reproducibility appendix, and HTML/JSON sidecars exist.",
            "- Phase 8.6 auto-export complete (default on): `findings.sarif`, `findings-fingerprints.json`, and `bounty/F-N.md` exist; `delta.md` exists when a baseline was found.",
            "",
            "## Run Context",
            "",
            f"- Target: `{repo}`",
            f"- Output: `{out}`",
            f"- Review depth: `{depth}`",
            f"- Modules: `{modules}`",
            f"- Routes: `{route_count}`",
            f"- Codex lane: `{codex_lane}`",
            f"- Local Qwen lane: `{qwen_lane}`",
            f"- Runtime: `{args.runtime}`",
            f"- Requirements file: `{args.requirements or 'none'}`",
            "",
            "## Completion Rule",
            "",
            "Mark the goal complete only after Phase 8 output exists and unsupported hunter/scanner claims have been removed.",
        ]
    )
    (out / "goals.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def shell_quote(value: str) -> str:
    if not value:
        return "''"
    if all(c.isalnum() or c in "/._:=,+-@" for c in value):
        return value
    return "'" + value.replace("'", "'\"'\"'") + "'"


def shell_expand_path(value: str) -> str:
    """Quote a generated shell path while preserving ${VAR} expansion."""
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def route_methods(methods_text: str | None) -> list[str]:
    if not methods_text:
        return []
    try:
        node = ast.parse(methods_text, mode="eval")
        if isinstance(node.body, (ast.List, ast.Tuple, ast.Set)):
            values = [
                item.value.upper()
                for item in node.body.elts
                if isinstance(item, ast.Constant) and isinstance(item.value, str)
            ]
            if values:
                return values
        if isinstance(node.body, ast.Constant) and isinstance(node.body.value, str):
            return [node.body.value.upper()]
    except SyntaxError:
        pass
    return [m.upper() for m in re.findall(r"[A-Za-z]+", methods_text) if m.upper() in {"GET", "POST", "PUT", "PATCH", "DELETE"}]


def route_is_public(route: dict) -> bool:
    auth = (route.get("auth") or "").strip("'\"").lower()
    return "public" in auth or auth == "none"


def route_path_has_params(path: str) -> bool:
    return bool(HTTP_ROUTE_PARAM_RE.search(path))


def runtime_probe_bucket(route: dict, path: str) -> str:
    methods = route_methods(route.get("methods"))
    route_type = (route.get("type") or "").strip("'\"").lower()
    if route_type and "json" in route_type:
        return "manual-json"
    if not route_is_public(route):
        return "manual-auth"
    if route_path_has_params(path):
        return "manual-params"
    if methods == ["GET"] or (methods and set(methods) == {"GET"}):
        return "auto-safe"
    if "GET" in methods:
        return "manual-mixed-methods"
    return "manual-unbounded-methods"


def write_runtime_probe_plan(out: Path, routes: list[dict], args: argparse.Namespace) -> None:
    if not args.runtime:
        return
    probe_dir = out / "runtime" / "probes"
    probe_dir.mkdir(parents=True, exist_ok=True)
    safe_list = probe_dir / "safe-pocs.txt"
    probe_records: list[dict] = []
    safe_scripts: list[Path] = []

    for idx, route in enumerate(routes, start=1):
        paths = route.get("paths") or []
        if not paths:
            probe_records.append({**route, "probe_bucket": "manual-dynamic-route", "probe_script": None})
            continue
        for path_idx, route_path in enumerate(paths, start=1):
            bucket = runtime_probe_bucket(route, route_path)
            script_name = f"probe-{idx:04d}-{path_idx:02d}.sh"
            script_path = probe_dir / script_name
            record = {
                "id": f"R{idx:04d}.{path_idx}",
                "module": route.get("module"),
                "file": route.get("file"),
                "line": route.get("line"),
                "function": route.get("function"),
                "path": route_path,
                "auth": route.get("auth"),
                "type": route.get("type"),
                "methods": route.get("methods"),
                "probe_bucket": bucket,
                "probe_script": str(script_path),
            }
            probe_records.append(record)
            body_file = f"${{ODOO_REVIEW_OUT}}/runtime/reproductions/{record['id']}-body.txt"
            header_file = f"${{ODOO_REVIEW_OUT}}/runtime/reproductions/{record['id']}-headers.txt"
            md_file = f"${{ODOO_REVIEW_OUT}}/runtime/reproductions/{record['id']}.md"
            lines = [
                "#!/usr/bin/env bash",
                "set -euo pipefail",
                ': "${ODOO_BASE_URL:?ODOO_BASE_URL is required}"',
                ': "${ODOO_REVIEW_OUT:?ODOO_REVIEW_OUT is required}"',
                "mkdir -p \"${ODOO_REVIEW_OUT}/runtime/reproductions\"",
                f"ROUTE_PATH={shell_quote(route_path)}",
                f"BUCKET={shell_quote(bucket)}",
                f"SOURCE={shell_quote(str(route.get('file')) + ':' + str(route.get('line')))}",
                "",
            ]
            if bucket != "auto-safe":
                lines.extend(
                    [
                        'if [[ "${ODOO_REVIEW_ALLOW_UNSAFE_PROBES:-0}" != "1" ]]; then',
                        f"  cat > {shell_expand_path(md_file)} <<EOF",
                        f"# Runtime Probe {record['id']}",
                        "",
                        f"- Source: \\`{route.get('file')}:{route.get('line')}\\`",
                        f"- Route: \\`{route_path}\\`",
                        f"- Bucket: \\`{bucket}\\`",
                        "",
                        "Skipped automatically. This route needs a human-reviewed PoC because it is authenticated, parameterized, JSON, mixed-method, or method-unbounded.",
                        "EOF",
                        "  exit 0",
                        "fi",
                        "",
                    ]
                )
            lines.extend(
                [
                    'URL="${ODOO_BASE_URL%/}${ROUTE_PATH}"',
                    f": > {shell_expand_path(header_file)}",
                    f": > {shell_expand_path(body_file)}",
                    f"STATUS=$(curl -ksS -L -X GET -D {shell_expand_path(header_file)} -o {shell_expand_path(body_file)} -w '%{{http_code}}' \"$URL\" || true)",
                    f"BODY_BYTES=$(wc -c < {shell_expand_path(body_file)} | tr -d ' ')",
                    f"cat > {shell_expand_path(md_file)} <<EOF",
                    f"# Runtime Probe {record['id']}",
                    "",
                    f"- Source: \\`{route.get('file')}:{route.get('line')}\\`",
                    f"- Function: \\`{route.get('function') or '?'}\\`",
                    f"- Route: \\`{route_path}\\`",
                    f"- Auth: \\`{route.get('auth')}\\`",
                    f"- Type: \\`{route.get('type')}\\`",
                    f"- Methods: \\`{route.get('methods') or '(unspecified)'}\\`",
                    f"- Bucket: \\`{bucket}\\`",
                    "- URL: \\`${URL}\\`",
                    "- HTTP status: \\`${STATUS}\\`",
                    "- Body bytes: \\`${BODY_BYTES}\\`",
                    f"- Headers: \\`{header_file}\\`",
                    f"- Body: \\`{body_file}\\`",
                    "",
                    "## First 80 Body Lines",
                    "",
                    "\\`\\`\\`text",
                    "EOF",
                    f"sed -n '1,80p' {shell_expand_path(body_file)} >> {shell_expand_path(md_file)} || true",
                    f"cat >> {shell_expand_path(md_file)} <<'EOF'",
                    "```",
                    "EOF",
                ]
            )
            script_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
            script_path.chmod(0o755)
            if bucket == "auto-safe":
                safe_scripts.append(script_path)

    safe_list.write_text("\n".join(str(path) for path in safe_scripts) + ("\n" if safe_scripts else ""), encoding="utf-8")
    (probe_dir / "probes.json").write_text(json.dumps(probe_records, indent=2), encoding="utf-8")
    runtime_cmd = [
        "odoo-review-runtime",
        str(out),
        "--run-generated-probes",
        "--odoo-bin",
        "/path/to/odoo-bin",
        "--config",
        "/path/to/odoo.conf",
        "--database",
        "review_db",
        "--addons-path",
        "/path/to/addons",
    ]
    if getattr(args, "odoomap_target", None):
        runtime_cmd.extend(["--odoomap-target", args.odoomap_target])
    readme_lines = [
        "# Runtime Probe Plan",
        "",
        "Generated from `inventory/routes.json` during `--runtime` runs.",
        "",
        "Auto-run probes are intentionally narrow: literal public routes with explicit `GET`-only methods. Everything else is emitted as a manual PoC template and exits without traffic unless `ODOO_REVIEW_ALLOW_UNSAFE_PROBES=1` is set.",
        "",
        f"- Total route/path probes: {len(probe_records)}",
        f"- Auto-safe probes: {len(safe_scripts)}",
        f"- Safe list: `{safe_list}`",
        f"- Machine plan: `{probe_dir / 'probes.json'}`",
        "",
        "Replay the generated safe probes after booting Odoo:",
        "",
        "```bash",
        " ".join(shell_quote(part) for part in runtime_cmd),
        "```",
    ]
    (probe_dir / "README.md").write_text("\n".join(readme_lines) + "\n", encoding="utf-8")


def write_directives_seed(out: Path) -> None:
    """Seed the directives feedback-loop directory with README + template."""
    directives_dir = out / "directives"
    directives_dir.mkdir(parents=True, exist_ok=True)
    (directives_dir / "results").mkdir(parents=True, exist_ok=True)

    readme = [
        "# Directives — Claude → Lane Feedback Loop",
        "",
        "Claude Code (the lead) writes directive files here when a lane needs to rerun with",
        "tighter focus or generate a new artifact. The `odoo-review-rerun` helper picks up a",
        "single directive file, dispatches it to the named lane (Qwen or Codex), writes the",
        "result alongside, and flips status to `done`.",
        "",
        "## Workflow",
        "",
        "1. Claude reads existing `.audit/` artifacts and decides a lane needs rework.",
        "2. Claude copies `_template.md` to `D-NNNN-<slug>.md` and fills in the YAML + body.",
        "3. Claude (or the user) runs:",
        "   ```bash",
        "   odoo-review-rerun .audit/directives/D-0001-portal-sudo.md",
        "   ```",
        "4. The helper writes `results/D-0001-portal-sudo.result.md` and updates the directive",
        "   frontmatter `status:` to `done` (or `failed`).",
        "5. Claude reads the result, decides whether to issue more directives or move on.",
        "",
        "## Status Lifecycle",
        "",
        "`pending` → `running` → `done` | `failed`",
        "",
        "## Naming",
        "",
        "`D-NNNN-<short-slug>.md` — incrementing 4-digit ID, lowercase slug. Keep slug short",
        "(`portal-sudo`, `xss-mail-template`, `idor-attachment-download`).",
        "",
        "## Examples",
        "",
        "- `D-0001-portal-sudo.md` — rescan `@http.route` + `sudo()` combos in `addons/portal/`",
        "- `D-0002-xss-evidence.md` — Codex builds PoC sketch for QWeb `t-raw` finding F-7",
        "- `D-0003-acl-coverage.md` — Qwen narrative on ACL gap in `hr_holidays` module",
        "",
        "Directives stay in this directory across runs. Already-`done` directives are skipped",
        "by the helper unless invoked with `--force`.",
        "",
    ]
    (directives_dir / "README.md").write_text("\n".join(readme) + "\n", encoding="utf-8")

    template = [
        "---",
        "id: D-NNNN",
        "created_at: YYYY-MM-DDTHH:MM:SSZ",
        "from_phase: \"5.5\"             # which phase issued this directive",
        "target_lane: codex             # qwen | codex",
        "task_type: rerun-hunter        # rerun-hunter | focus-scan | build-poc | verify-claim | narrative",
        "status: pending                # pending | running | done | failed",
        "model:                         # optional override (e.g. qwen3:0.6b, gpt-5.3-codex)",
        "scope:",
        "  - addons/<module>/<file>.py  # one or more paths relative to repo root",
        "deadline_phase: \"6\"            # latest phase that can still consume this result",
        "---",
        "",
        "## Why",
        "",
        "Short reason this directive exists. What did Claude observe in the current artifacts",
        "that warrants a focused rerun?",
        "",
        "## Ask",
        "",
        "One specific question or task. Avoid open-ended sweeps — directives are for targeted",
        "follow-ups, not full hunter passes.",
        "",
        "## Expected Output",
        "",
        "Describe the shape of the answer (markdown table, PoC script, narrative paragraph,",
        "evidence bundle). The helper writes the lane's response to",
        "`results/<id>-<slug>.result.md`.",
        "",
        "## Constraints",
        "",
        "- Read-only unless `task_type: build-poc` (then `workspace-write` under `<OUT>`).",
        "- Cite file:line for every claim. No speculation.",
        "- Hint-only if `target_lane: qwen` — no ACCEPT/REJECT verdicts.",
        "",
    ]
    (directives_dir / "_template.md").write_text("\n".join(template) + "\n", encoding="utf-8")


def write_qwen_handoff(out: Path, args: argparse.Namespace, repo: Path) -> None:
    """Write a token-pressure handoff packet for local Qwen.

    Claude token exhaustion is not visible to this runner, so the practical
    design is a standing escape hatch: when the lead context gets tight, dispatch
    these Qwen directives for hint-only triage and fold results back into Phase
    6/7 after compaction or a fresh lead session.
    """
    handoff = out / "qwen-handoff"
    handoff.mkdir(parents=True, exist_ok=True)
    directives = out / "directives"
    local_model = args.local_model
    readme = [
        "# Qwen Handoff",
        "",
        "Use this when the lead Claude context is getting tight. Qwen is local and",
        "hint-only: it can summarize risk, cluster leads, and identify obvious noise,",
        "but it cannot ACCEPT/REJECT final findings or set severity.",
        "",
        "## Dispatch",
        "",
        "```bash",
        f"odoo-review-rerun {directives / 'D-9001-qwen-risk-cluster.md'} --repo {repo}",
        f"odoo-review-rerun {directives / 'D-9002-qwen-fp-triage.md'} --repo {repo}",
        f"odoo-review-rerun {directives / 'D-9003-qwen-evidence-gaps.md'} --repo {repo}",
        "```",
        "",
        "Then read `directives/results/D-900*.result.md` and fold useful hints into",
        "Phase 6/7. If Claude runs out of context, restart from `00-run-mode.md`,",
        "`qwen-handoff/README.md`, and the directive results.",
        "",
        "## Guardrails",
        "",
        "- Qwen output is HINT only.",
        "- Every claim still needs file:line verification by Claude or Codex.",
        "- Do not suppress or accept findings based on Qwen alone.",
    ]
    (handoff / "README.md").write_text("\n".join(readme) + "\n", encoding="utf-8")

    directive_specs = [
        (
            "D-9001-qwen-risk-cluster.md",
            "risk-cluster",
            "Cluster the highest-risk Odoo modules and candidate leads from inventory and scanner artifacts. Focus on public routes, sudo propagation, raw SQL, unsafe QWeb, portal exposure, and multi-company leakage. Return a concise prioritized list with file:line pointers when available.",
        ),
        (
            "D-9002-qwen-fp-triage.md",
            "fp-triage",
            "Review scanner and hunter leads for obvious false-positive patterns under Odoo semantics. Explain why each looks likely-noise, citing the framework invariant. Do not issue final REJECT verdicts.",
        ),
        (
            "D-9003-qwen-evidence-gaps.md",
            "evidence-gaps",
            "Review candidate findings and identify missing evidence needed for Phase 7 gates: source match, reachability, attacker control, realistic preconditions, PoC shape, and severity impact. Return a checklist grouped by finding or module.",
        ),
    ]
    for filename, task_type, ask in directive_specs:
        path = directives / filename
        if path.exists():
            continue
        directive_id = "-".join(filename.split("-", 2)[:2])
        path.write_text(
            "\n".join([
                "---",
                f"id: {directive_id}",
                "created_at: AUTO",
                "from_phase: \"handoff\"",
                "target_lane: qwen",
                f"task_type: {task_type}",
                "status: pending",
                f"model: {local_model}",
                "scope:",
                "deadline_phase: \"7\"",
                "---",
                "",
                "## Context",
                "",
                f"Repo: `{repo}`",
                f"Audit output: `{out}`",
                "",
                "Read these artifacts if present:",
                "",
                f"- `{out / '00-modules.md'}`",
                f"- `{out / '01-attack-surface.md'}`",
                f"- `{out / 'module-risk.md'}`",
                f"- `{out / 'inventory' / 'sharp-edge-index.json'}`",
                f"- `{out / 'inventory' / 'breadth' / 'leads.md'}`",
                f"- `{out / 'scans'}`",
                f"- `{out / 'codex' / 'hunters'}`",
                f"- `{out / 'baseline-stock' / 'validation-leads.md'}`",
                "",
                "## Ask",
                "",
                ask,
                "",
                "## Output Rules",
                "",
                "- HINT only. Do not produce final ACCEPT/REJECT verdicts.",
                "- Cite file:line where possible.",
                "- Keep it concise enough for a lead session to consume after compaction.",
            ]) + "\n",
            encoding="utf-8",
        )


def breadth_budget_defaults(args: argparse.Namespace) -> tuple[int | None, int]:
    """Return (max_chunks, min_module_score) for Phase 1.7 breadth dispatch."""
    if args.no_breadth or args.breadth_budget == "off":
        return 0, 99
    defaults = {
        "low": (8, 25),
        "normal": (24, 10),
        "deep": (None, 0),
    }
    max_chunks, min_score = defaults[args.breadth_budget]
    if args.breadth_max_chunks and args.breadth_max_chunks > 0:
        max_chunks = args.breadth_max_chunks
    return max_chunks, min_score


def emit_breadth_dispatch(out: Path, manifests: list[dict], routes: list[dict], pattern_summary: dict, risk_rows: list[dict], args: argparse.Namespace) -> None:
    """Emit Phase 1.7 breadth-sweep dispatch plan.

    Lead Claude reads inventory/breadth/dispatch.json and spawns one Agent per
    chunk to do an eve-cc style breadth pass. Outputs go to inventory/breadth/leads.md.
    """
    max_chunks, min_score = breadth_budget_defaults(args)
    if max_chunks == 0:
        return
    breadth_dir = out / "inventory" / "breadth"
    breadth_dir.mkdir(parents=True, exist_ok=True)

    py_by_module: dict[str, list[str]] = {}
    for item in manifests:
        module = item["module"]
        loose_file = item.get("_loose_file")
        if loose_file:
            py_by_module.setdefault(module, []).append(loose_file)
            continue
        module_dir = (Path(args.target).expanduser().resolve() / item["dir"]).resolve()
        if not module_dir.exists():
            continue
        for path in sorted(module_dir.rglob("*.py")):
            if should_skip(path):
                continue
            try:
                py_by_module.setdefault(module, []).append(str(path.relative_to(Path(args.target).expanduser().resolve())))
            except ValueError:
                py_by_module.setdefault(module, []).append(str(path))

    sharp = pattern_summary.get("by_module", {})
    score_by_module = {row.get("module"): int(row.get("score", 0) or 0) for row in risk_rows}
    route_count_by_module: dict[str, int] = {}
    for route in routes:
        module = route.get("module")
        if module:
            route_count_by_module[module] = route_count_by_module.get(module, 0) + 1

    chunks: list[dict] = []
    chunk_id = 1
    chunk_size = max(1, args.breadth_chunk_size)
    for module in sorted(py_by_module.keys()):
        module_score = score_by_module.get(module, 0)
        if module_score < min_score:
            continue
        files = py_by_module[module]
        module_sharp = sharp.get(module, {})
        sharp_count = sum(int(v or 0) for v in module_sharp.values() if isinstance(v, int))
        for i in range(0, len(files), chunk_size):
            piece = files[i:i + chunk_size]
            chunks.append({
                "chunk_id": f"BR-{chunk_id:03d}",
                "module": module,
                "files": piece,
                "file_count": len(piece),
                "module_score": module_score,
                "route_count": route_count_by_module.get(module, 0),
                "sharp_edge_count": sharp_count,
                "sharp_edges_in_module": module_sharp,
                "agent": "Agent",
                "subagent_type": "general-purpose",
                "objective": "eve-cc style breadth review for Odoo security: enumerate every public route, sudo() use, sql_query, eval/exec, ir.rule gap, and authentication boundary in this chunk; output candidate findings as leads (file:line, attack idea, suspected severity).",
            })
            chunk_id += 1

    chunks.sort(
        key=lambda c: (
            int(c.get("module_score", 0)),
            int(c.get("route_count", 0)),
            int(c.get("sharp_edge_count", 0)),
            int(c.get("file_count", 0)),
        ),
        reverse=True,
    )
    total_candidate_chunks = len(chunks)
    if max_chunks is not None:
        chunks = chunks[:max_chunks]
    for idx, chunk in enumerate(chunks, start=1):
        chunk["chunk_id"] = f"BR-{idx:03d}"

    dispatch_path = breadth_dir / "dispatch.json"
    dispatch_path.write_text(json.dumps({
        "breadth_budget": args.breadth_budget,
        "breadth_max_chunks": max_chunks,
        "breadth_min_module_score": min_score,
        "candidate_chunks_before_cap": total_candidate_chunks,
        "chunks": chunks,
    }, indent=2), encoding="utf-8")

    md_lines = ["# Phase 1.7 — Breadth Sweep Dispatch", ""]
    md_lines.append(f"Budget: `{args.breadth_budget}`")
    md_lines.append(f"Total chunks: {len(chunks)} (chunk size {chunk_size}; candidates before cap {total_candidate_chunks})")
    md_lines.append(f"Minimum module risk score: `{min_score}`")
    md_lines.append("")
    md_lines.append("Lead Claude: dispatch only the chunks listed here via the Agent tool in parallel batches.")
    md_lines.append("Each subagent reviews its file slice for Odoo-specific security issues and")
    md_lines.append("appends its leads to `inventory/breadth/leads.md` (one section per chunk).")
    md_lines.append("Hunters in Phase 5 read leads.md as additional input.")
    md_lines.append("If limits get tight, stop breadth after the current wave; the prioritized chunks already front-load risk.")
    md_lines.append("")
    md_lines.append("| Chunk | Module | Files | Risk Score | Routes | Sharp Edges |")
    md_lines.append("|-------|--------|-------|------|--------|-------------|")
    for c in chunks:
        md_lines.append(f"| {c['chunk_id']} | {c['module']} | {c['file_count']} | {c['module_score']} | {c['route_count']} | {c['sharp_edge_count']} |")
    (breadth_dir / "dispatch.md").write_text("\n".join(md_lines) + "\n", encoding="utf-8")

    leads_path = breadth_dir / "leads.md"
    if not leads_path.exists():
        leads_path.write_text(
            "# Phase 1.7 — Breadth Sweep Leads\n\n"
            "_Lead Claude appends one section per chunk after dispatch completes._\n\n"
            "## Format\n\n"
            "```\n"
            "## BR-NNN — <module>\n"
            "- file:line — <one-line lead>\n"
            "```\n",
            encoding="utf-8",
        )


def assert_phase1_populated(out: Path, manifests: list[dict], args: argparse.Namespace) -> list[str]:
    """Phase 1 fail-loud: assert 01-attack-surface.md has at least N lines per in-scope module.

    Returns list of error strings (empty if pass).
    """
    if args.no_phase1_assert:
        return []
    surface_path = out / "01-attack-surface.md"
    if not surface_path.exists():
        return [f"Phase 1 fail-loud: {surface_path} does not exist"]
    text = surface_path.read_text(encoding="utf-8")
    errors: list[str] = []
    threshold = max(1, args.phase1_min_lines_per_module)
    for item in manifests:
        module = item["module"]
        marker = f"### `{module}`"
        if marker not in text:
            errors.append(f"Phase 1 fail-loud: module `{module}` missing per-module surface section in 01-attack-surface.md")
            continue
        idx = text.index(marker)
        next_marker_idx = text.find("\n### ", idx + len(marker))
        section = text[idx:next_marker_idx] if next_marker_idx != -1 else text[idx:]
        non_empty_lines = [line for line in section.splitlines() if line.strip() and not line.strip().startswith("#")]
        if len(non_empty_lines) < threshold:
            errors.append(f"Phase 1 fail-loud: module `{module}` only has {len(non_empty_lines)} content line(s) in 01-attack-surface.md (threshold: {threshold})")
    return errors


def preflight(args: argparse.Namespace, repo: Path, out: Path) -> tuple[dict, list[str]]:
    tools = {name: which(name) for name in ["codex", "ollama", "semgrep", "bandit", "ruff", "pylint", "pre-commit", "codeql", "pyre", "pip-audit", "osv-scanner", "detect-secrets", "joern-parse", "dot"]}
    lane_errors: list[str] = []
    if not args.no_codex and not tools["codex"]:
        lane_errors.append("Codex CLI not found; use --no-codex or --allow-missing-lanes.")
    if not args.no_local_qwen:
        if not tools["ollama"]:
            lane_errors.append("Ollama not found; use --no-local-qwen or --allow-missing-lanes.")
        else:
            try:
                listed = subprocess.run(["ollama", "list"], text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=15)
                if args.local_model not in listed.stdout:
                    lane_errors.append(f"Ollama model {args.local_model!r} not found; pull it or use --allow-missing-lanes.")
            except Exception as exc:  # noqa: BLE001
                lane_errors.append(f"Could not query Ollama models: {exc}")
    plan = {
        "target": str(repo),
        "out": str(out),
        "created_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "odoo_version": args.odoo_version,
        "modules": args.modules,
        "project_config": getattr(args, "project_config_loaded", None),
        "project_config_warnings": getattr(args, "project_config_warnings", []),
        "model_pack": args.model_pack,
        "quick": args.quick,
        "local_qwen_enabled": not args.no_local_qwen,
        "local_model": args.local_model,
        "codex_enabled": not args.no_codex,
        "codex_model": args.codex_model,
        "codex_budget": args.codex_budget,
        "codex_mode": args.codex_mode,
        "ensemble": args.ensemble,
        "ensemble_passes": args.ensemble_passes,
        "runtime": args.runtime,
        "zap_target": args.zap_target,
        "odoomap_target": args.odoomap_target,
        "requirements": args.requirements,
        "emit_json": args.emit_json,
        "emit_html": not args.no_html,
        "auto_export": not args.no_export,
        "baseline": args.baseline,
        "scope": args.scope,
        "pr": args.pr,
        "pr_repo": args.pr_repo,
        "tools": tools,
        "lane_errors": lane_errors,
    }
    return plan, lane_errors


def run_scanners(args: argparse.Namespace, repo: Path, out: Path, log_path: Path) -> list[dict]:
    if args.quick or args.no_scans:
        progress("skip scanners (--quick or --no-scans)")
        return [{"phase": "scans", "status": "skipped", "reason": "--quick or --no-scans"}]
    progress("Phase 2-4.5 scanners starting")
    records = []
    scans = out / "scans"
    for sub in ["semgrep", "bandit", "ruff", "pylint-odoo", "oca-precommit", "codeql", "joern", "pysa", "deps", "secrets"]:
        (scans / sub).mkdir(parents=True, exist_ok=True)

    if which("semgrep"):
        records.append(run(["semgrep", "--config", str(DEFAULT_RULES), "--config", "p/python", "--config", "p/owasp-top-ten", "--config", "p/trailofbits", "--json", "--output", str(scans / "semgrep" / "results.json"), "--metrics=off", str(repo)], repo, log_path, timeout=2400))
        records.append(run(["semgrep", "--config", str(DEFAULT_RULES), "--config", "p/python", "--sarif", "--output", str(scans / "semgrep" / "results.sarif"), "--metrics=off", str(repo)], repo, log_path, timeout=2400))
    else:
        records.append({"tool": "semgrep", "status": "missing"})

    if which("bandit"):
        records.append(run(["bandit", "-r", str(repo), "-f", "json", "-o", str(scans / "bandit" / "results.json"), "-lll", "--exclude", "*/tests/*,*/test_*"], repo, log_path))
    else:
        records.append({"tool": "bandit", "status": "missing"})

    if which("ruff"):
        records.append(run(["ruff", "check", str(repo), "--output-format=json"], repo, log_path, scans / "ruff" / "results.json"))
    else:
        records.append({"tool": "ruff", "status": "missing"})

    if which("pylint"):
        records.append(run(["pylint", "--load-plugins", "pylint_odoo", "--disable=all", "--enable=odoolint", str(repo)], repo, log_path, scans / "pylint-odoo" / "results.txt", timeout=2400))
    else:
        records.append({"tool": "pylint", "status": "missing"})

    if which("pre-commit") and (repo / ".pre-commit-config.yaml").exists():
        records.append(run(["pre-commit", "run", "--all-files", "--config", str(repo / ".pre-commit-config.yaml")], repo, log_path, scans / "oca-precommit" / "results.txt", timeout=2400))
    else:
        records.append({"tool": "pre-commit", "status": "missing_or_no_config"})

    if which("codeql"):
        db = out / "codeql-dbs" / f"{repo.name or 'repo'}-python-db"
        db.parent.mkdir(parents=True, exist_ok=True)
        records.append(run(["codeql", "database", "create", str(db), "--language=python", f"--source-root={repo}", "--build-mode=none"], repo, log_path, timeout=3600))
        records.append(run(["codeql", "database", "analyze", str(db), "codeql/python-queries:codeql-suites/python-security-and-quality.qls", "codeql/python-queries:codeql-suites/python-security-experimental.qls", "--format=sarif-latest", f"--output={scans / 'codeql' / 'results.sarif'}", "--download"], repo, log_path, timeout=3600))
    else:
        records.append({"tool": "codeql", "status": "missing"})

    if args.joern and which("joern-parse"):
        cpg = scans / "joern" / "cpg.bin"
        records.append(run(["joern-parse", str(repo), "--language", "pythonsrc", "-o", str(cpg)], repo, log_path, timeout=3600))
    elif args.joern:
        records.append({"tool": "joern-parse", "status": "missing"})

    if which("pip-audit"):
        records.append(run(["pip-audit", "--path", str(repo), "--format", "json", "--output", str(scans / "deps" / "pip-audit.json")], repo, log_path, timeout=1800))
    else:
        records.append({"tool": "pip-audit", "status": "missing"})

    if which("osv-scanner"):
        records.append(run(["osv-scanner", "--recursive", "--format", "json", "--output", str(scans / "deps" / "osv-scanner.json"), str(repo)], repo, log_path, timeout=1800))
    else:
        records.append({"tool": "osv-scanner", "status": "missing"})

    if which("detect-secrets"):
        records.append(run(["detect-secrets", "scan", "--all-files", str(repo)], repo, log_path, scans / "secrets" / "detect-secrets.json", timeout=1800))
    else:
        records.append({"tool": "detect-secrets", "status": "missing"})
    progress("Phase 2-4.5 scanners complete")
    return records


def run_qwen(args: argparse.Namespace, repo: Path, out: Path, log_path: Path) -> dict:
    qwen_dir = out / "local-qwen"
    qwen_dir.mkdir(parents=True, exist_ok=True)
    if args.no_local_qwen:
        progress("skip local Qwen (--no-local-qwen)")
        return {"status": "skipped", "reason": "--no-local-qwen"}
    if not which("ollama"):
        progress("skip local Qwen (ollama missing)")
        return {"status": "skipped", "reason": "ollama missing"}
    progress(f"Phase 1.5 local Qwen starting ({args.local_model})")
    def excerpt(path: Path, limit: int = 12000) -> str:
        if not path.exists():
            return f"(missing: {path})"
        text = clean_output(path.read_text(encoding="utf-8", errors="replace"))
        return text[:limit]

    prompt = f"""You are a local HINT-only reviewer for an Odoo source audit.
Do not create final findings. Do not speculate about files you did not see.
Only use the artifact excerpts pasted below. If evidence is insufficient, say so.

Return three short sections:
1. Module risk notes
2. Scanner triage hints
3. Obvious reject candidates

Rules:
- HINT only: no ACCEPT/REJECT final verdicts.
- Cite module names or file paths from the excerpts.
- Do not mention missing validation/encryption unless an excerpt shows it.
- Keep the response under 80 lines.

## 00-modules.md excerpt
{excerpt(out / '00-modules.md', 10000)}

## 01-attack-surface.md excerpt
{excerpt(out / '01-attack-surface.md', 14000)}

## module-risk.md excerpt
{excerpt(out / 'module-risk.md', 9000)}

## sharp-edge-index.json excerpt
{excerpt(out / 'inventory' / 'sharp-edge-index.json', 14000)}
"""
    result = run(["ollama", "run", args.local_model, prompt], repo, log_path, qwen_dir / "module-notes.md", timeout=900)
    (qwen_dir / "scanner-triage.md").write_text("See module-notes.md. Scanner-specific triage is advisory only.\n", encoding="utf-8")
    (qwen_dir / "reject-candidates.md").write_text("See module-notes.md. Claude must verify before rejecting anything.\n", encoding="utf-8")
    progress("Phase 1.5 local Qwen complete")
    return result


def codex_prompt(name: str, title: str, focus: str, repo: Path, out: Path, args: argparse.Namespace) -> str:
    depth = {
        "low": "Prioritize highest-risk public/portal surfaces and scanner hits. Keep output concise.",
        "normal": "Review the whole scoped repo with emphasis on reachable Odoo trust-boundary bugs.",
        "deep": "Do a deep pass across the whole scoped repo, including lower-risk modules and variants.",
    }[args.codex_budget]
    return f"""You are the odoo-code-review {title} hunter for an Odoo source-code audit.

Repository: {repo}
Audit output directory: {out}
Focus: {focus}
Depth: {depth}

Use these artifacts first:
- {out / '00-modules.md'}
- {out / '01-attack-surface.md'}
- {out / '00-accepted-risks.md'}
- {out / 'inventory' / 'manifests.json'}
- {out / 'inventory' / 'routes.json'}
- {out / 'inventory' / 'acl-index.json'}
- {out / 'inventory' / 'sharp-edge-index.json'}
- {out / 'inventory' / 'accepted-risks.json'}
- {out / 'inventory' / 'fix-list.json'}
- {out / 'inventory' / 'py-files-by-module.json'}
- {out / 'inventory' / 'breadth' / 'leads.md'} if present (breadth-pass leads from Phase 1.7)
- {out / 'local-qwen' / 'module-notes.md'} if present
- scanner outputs under {out / 'scans'} if present

Coverage-proof contract (MANDATORY):
- Read `inventory/py-files-by-module.json`. For every module in scope, you MUST
  open and read at least one file relevant to your hunter focus. If a module has
  zero files matching your focus, write a one-line justification.
- Emit a `Reviewed:` block at the very top of your output, listing each module
  on its own line as: `module_name: file_a.py:Lstart-Lend, file_b.py:Lstart-Lend`
  (use real line ranges you actually inspected; do NOT fabricate). When you
  skipped a module, write: `module_name: SKIPPED — <one-line reason>`.
- Empty Reviewed: blocks are a contract violation. Phase 5.6 will diff your
  Reviewed: list against py-files-by-module.json and flag missing modules.

Suppression contract (accepted-risks.json):
- Load the `active` array. Before emitting any finding, compute its fingerprint
  (sha256 over normalized "{{file}}:{{primary_line}}:{{sink_kind}}:{{title_lower}}",
   first 16 hex chars).
- If a finding fingerprint appears in any `active.fingerprint`, drop it silently.
- Otherwise, fall back to legacy match: if `file` matches and `lines` range contains
  the primary line and `match` regex/substring matches code at that line, drop it.
- For `expired` entries, emit the finding normally and add a note:
  "Expired accepted-risk AR-NNN — re-review."
- Stale entries are not your concern.
- Never write to the accepted-risks file.

Tracking contract (fix-list.json):
- Load the `active` array. After computing the fingerprint for an emitted finding,
  check whether any fix-list entry matches via fingerprint (or file+lines fallback).
- DO NOT suppress on a fix-list match — fix-list is a tracker, not a filter.
- If the matched entry has `status` open or in-progress, add a note:
  "Tracked by FIX-NNN (target YYYY-MM-DD)."
- If the matched entry has `status` fixed, add a note flagged as REGRESSION:
  "REGRESSION — fix-list FIX-NNN marked status=fixed but the bug is still present."
- If the matched entry has `status` wontfix, add a note:
  "wontfix per FIX-NNN — see notes."
- Never write to the fix-list file.

Output candidate findings only. For each candidate include:
- title
- affected file:line
- attacker role needed
- source-to-sink path
- concrete payload or reproduction sketch
- why Odoo ACL/record rules do not block it
- severity suggestion with confidence
- what Claude must verify in Phase 7
- fingerprint (16-hex) computed as above

Do not report style issues, scanner-only issues, or theoretical risks without a sink.
"""


def run_codex(args: argparse.Namespace, repo: Path, out: Path, log_path: Path) -> list[dict]:
    codex_dir = out / "codex" / "hunters"
    prompt_dir = codex_dir / "prompts"
    prompt_dir.mkdir(parents=True, exist_ok=True)
    records = []
    if args.no_codex:
        progress("skip Codex hunters (--no-codex)")
        return [{"status": "skipped", "reason": "--no-codex"}]
    if not which("codex"):
        progress("skip Codex hunters (codex missing)")
        return [{"status": "skipped", "reason": "codex missing"}]
    progress(f"Phase 5 Codex hunters starting ({len(HUNTERS)} hunters, mode={args.codex_mode})")
    for idx, (slug, title, focus) in enumerate(HUNTERS, start=1):
        progress(f"Codex hunter {idx}/{len(HUNTERS)} start: {title}")
        prompt = codex_prompt(slug, title, focus, repo, out, args)
        prompt_path = prompt_dir / f"{slug}.md"
        output_path = codex_dir / f"{slug}.md"
        prompt_path.write_text(prompt, encoding="utf-8")
        if args.codex_mode == "prepare":
            records.append({"hunter": slug, "status": "prepared", "prompt": str(prompt_path), "output": str(output_path)})
            progress(f"Codex hunter {idx}/{len(HUNTERS)} prepared: {title}")
            continue
        cmd = [
            "codex",
            "exec",
            "-C",
            str(repo),
            "-m",
            args.codex_model,
            "-s",
            "read-only",
            "--skip-git-repo-check",
            "-o",
            str(output_path),
            prompt,
        ]
        record = run(cmd, repo, log_path, output_path, timeout=3600)
        record["hunter"] = slug
        records.append(record)
        progress(f"Codex hunter {idx}/{len(HUNTERS)} done: {title} exit={record.get('returncode')}")
    progress("Phase 5 Codex hunters complete")
    return records


def ensemble_pass_count(args: argparse.Namespace) -> int:
    if args.ensemble == "off":
        return 0
    if args.ensemble_passes and args.ensemble_passes > 0:
        return min(args.ensemble_passes, len(ENSEMBLE_FOCI))
    return 6 if args.ensemble == "cheap" else len(ENSEMBLE_FOCI)


def ensemble_prompt(pass_id: str, title: str, focus: str, repo: Path, out: Path, args: argparse.Namespace) -> str:
    return f"""You are running an Odoo security recall ensemble pass.

Mode: {args.ensemble}
Pass: {pass_id} — {title}
Goal: maximize recall for this one bug class. You are allowed to emit noisy candidate leads, but every lead must be grounded in file:line evidence and a concrete Odoo exploit shape.

Focus:
{focus}

Read these artifacts first:
- {out / '00-modules.md'}
- {out / '01-attack-surface.md'}
- {out / 'module-risk.md'}
- {out / 'inventory' / 'routes.json'}
- {out / 'inventory' / 'acl-index.json'}
- {out / 'inventory' / 'sharp-edge-index.json'}
- {out / 'inventory' / 'py-files-by-module.json'}
- {out / 'inventory' / 'accepted-risks.json'}
- {out / 'inventory' / 'fix-list.json'}
- {out / 'runtime' / 'probes' / 'probes.json'} if present
- {out / 'runtime' / 'reproductions'} if present
- {out / 'inventory' / 'breadth' / 'leads.md'} if present
- scanner outputs under {out / 'scans'} if present

Output to this file only. Do not edit source.

Output format:
Reviewed:
- module_name: file.py:Lstart-Lend or SKIPPED — reason

Candidates:
1. Title
   - File: path:line
   - Attacker role:
   - Source-to-sink path:
   - Odoo boundary crossed:
   - Concrete payload/reproduction sketch:
   - Runtime probe tie-in, if any:
   - Why this might be false positive:
   - Phase 7 validation checklist:
   - Fingerprint input suggestion: file:line:sink_kind:title

Rules:
- Do not create final ACCEPT/REJECT findings.
- Do not report generic style or best-practice issues.
- Prefer Odoo-specific security shapes over generic Python findings.
- If you find nothing, explain what files and route/model surfaces you checked.
"""


def run_ensemble(args: argparse.Namespace, repo: Path, out: Path, log_path: Path) -> list[dict]:
    count = ensemble_pass_count(args)
    ens_dir = out / "ensemble"
    prompt_dir = ens_dir / "prompts"
    prompt_dir.mkdir(parents=True, exist_ok=True)
    selected = ENSEMBLE_FOCI[:count]
    plan = {
        "enabled": args.ensemble != "off",
        "mode": args.ensemble,
        "passes": [
            {"index": idx, "slug": slug, "title": title, "focus": focus}
            for idx, (slug, title, focus) in enumerate(selected, start=1)
        ],
        "model": args.codex_model,
        "budget": args.codex_budget,
        "codex_mode": args.codex_mode,
    }
    (ens_dir / "plan.json").write_text(json.dumps(plan, indent=2), encoding="utf-8")
    readme = [
        "# Ensemble Recall Passes",
        "",
        "These passes are recall-oriented. They intentionally produce candidate leads, not final findings.",
        "Phase 7 still performs the strict 6-gate validation and runtime evidence review.",
        "",
        f"- Mode: `{args.ensemble}`",
        f"- Passes: `{count}`",
        f"- Model: `{args.codex_model}`",
        "",
        "After passes complete, lead Claude should dedupe candidates into `merged-leads.md` and promote only validated findings into Phase 7.",
    ]
    (ens_dir / "README.md").write_text("\n".join(readme) + "\n", encoding="utf-8")
    merged = ens_dir / "merged-leads.md"
    if not merged.exists():
        merged.write_text("# Ensemble Merged Leads\n\n_Lead Claude dedupes pass outputs here before Phase 7 validation._\n", encoding="utf-8")
    if args.ensemble == "off":
        return [{"status": "skipped", "reason": "--ensemble off"}]
    if args.no_codex:
        return [{"status": "skipped", "reason": "--no-codex", "plan": str(ens_dir / "plan.json")}]
    if not which("codex"):
        return [{"status": "skipped", "reason": "codex missing", "plan": str(ens_dir / "plan.json")}]

    records: list[dict] = []
    progress(f"Ensemble recall starting ({count} passes, mode={args.ensemble}, codex_mode={args.codex_mode})")
    for idx, (slug, title, focus) in enumerate(selected, start=1):
        pass_id = f"pass-{idx:02d}-{slug}"
        prompt = ensemble_prompt(pass_id, title, focus, repo, out, args)
        prompt_path = prompt_dir / f"{pass_id}.md"
        output_path = ens_dir / f"{pass_id}.md"
        prompt_path.write_text(prompt, encoding="utf-8")
        if args.codex_mode == "prepare" or args.preflight_only:
            records.append({"pass": pass_id, "status": "prepared", "prompt": str(prompt_path), "output": str(output_path)})
            continue
        cmd = [
            "codex",
            "exec",
            "-C",
            str(repo),
            "-m",
            args.codex_model,
            "-s",
            "read-only",
            "--skip-git-repo-check",
            "-o",
            str(output_path),
            prompt,
        ]
        record = run(cmd, repo, log_path, output_path, timeout=3600)
        record["pass"] = pass_id
        records.append(record)
    progress("Ensemble recall complete")
    return records


def write_tooling(out: Path, plan: dict, scanner_records: list[dict], qwen_record: dict | None, codex_records: list[dict] | None, ensemble_records: list[dict] | None = None) -> None:
    data = {
        "plan": plan,
        "scanner_records": scanner_records,
        "qwen_record": qwen_record,
        "codex_records": codex_records,
        "ensemble_records": ensemble_records,
    }
    (out / "tooling.json").write_text(json.dumps(data, indent=2), encoding="utf-8")
    lines = ["# Tooling and Run Plan", ""]
    lines.append(f"Target: `{plan['target']}`")
    lines.append(f"Output: `{plan['out']}`")
    lines.append(f"Created: `{plan['created_at']}`")
    lines.append(f"Odoo version override: `{plan.get('odoo_version') or 'not provided'}`")
    lines.append(f"Project config: `{plan.get('project_config') or 'not loaded'}`")
    lines.append(f"Model pack: `{plan.get('model_pack')}`")
    lines.append(f"Local Qwen enabled: `{plan['local_qwen_enabled']}` (`{plan['local_model']}`)")
    lines.append(f"Codex enabled: `{plan['codex_enabled']}` (`{plan['codex_model']}`, budget `{plan['codex_budget']}`, mode `{plan['codex_mode']}`)")
    lines.append(f"Ensemble: `{plan.get('ensemble')}` (passes `{plan.get('ensemble_passes')}`)")
    lines.append(f"Runtime enabled: `{plan['runtime']}`")
    if plan.get("project_config_warnings"):
        lines.append("")
        lines.append("## Project Config Warnings")
        lines.extend(f"- {warning}" for warning in plan["project_config_warnings"])
    lines.append("")
    lines.append("## Tool Paths")
    lines.append("")
    for name, path in sorted(plan["tools"].items()):
        lines.append(f"- `{name}`: `{path or 'missing'}`")
    if plan["lane_errors"]:
        lines.append("")
        lines.append("## Lane Errors")
        lines.extend(f"- {error}" for error in plan["lane_errors"])
    (out / "tooling.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def autodetect_weekly_paths(args: argparse.Namespace, repo: Path) -> None:
    """When -ks/--kitchensink is set, auto-detect durable review state in the repo root unless explicitly overridden."""
    if not args.weekly:
        return
    if not args.baseline:
        candidates = [repo / ".audit-baseline" / "findings.json", repo / ".audit-baseline"]
        for c in candidates:
            if c.exists():
                args.baseline = str(c)
                break
    if not args.scope:
        for name in ("scope.yml", "scope.yaml", ".audit-scope.yml"):
            p = repo / name
            if p.exists():
                args.scope = str(p)
                break
    # accepted-risks/fix-list auto-load already lives in load_accepted_risks/load_fix_list — no override needed when user didn't pass --accepted-risks/--fix-list.


def write_baseline_stock_dispatch(out: Path, args: argparse.Namespace, repo: Path) -> None:
    """Emit the dispatch packet for the --baseline-stock-cc lane.

    Lead Claude reads this and spawns one general-purpose Agent that reviews the
    repo with no harness scaffolding. The control lane exists because a plain
    Claude Code review sometimes finds bugs specialist lanes miss; stock-only
    outputs must be reviewed in the current run before final findings close.
    """
    if not getattr(args, "baseline_stock_cc", False):
        return
    if args.preflight_only:
        orchestration_note = "This preflight-only run only writes the dispatch packet. Run from Claude Code for stock-CC subagent orchestration."
    else:
        orchestration_note = "Direct CLI cannot spawn the stock-CC subagent. Run `/odoo-code-review <repo> -ks` from Claude Code or manually execute the prompt in this directory before finalize."
    bs_dir = out / "baseline-stock"
    bs_dir.mkdir(parents=True, exist_ok=True)
    prompt = f"""You are the **stock-Claude-Code control lane** for an Odoo source-code security review. The harness is also reviewing this repo separately. Your job: produce findings the way stock CC naturally would, with NO harness scaffolding, NO Phase 0/1 maps, NO hunter assignments.

## Repo
{repo}

## Task
Review every Python file under {repo}/addons (or `**/__manifest__.py` parents). Find real, exploitable Odoo security bugs. For each finding emit:

- `Title:` short title
- `File:` `relative/path:line`
- `Severity:` CRITICAL | HIGH | MEDIUM | LOW
- `Sink:` the dangerous call/pattern (e.g. `cr.execute(f"...")`, `auth='public' + sudo()`, `t-raw on user data`)
- `Why:` 1-2 sentences on exploitability
- `PoC:` 1-3 lines (curl, XML-RPC, or odoo-shell)

Do NOT pad with "missing input validation" nits. Real exploitable bugs only — same bar the harness uses.

Write all findings to `{bs_dir}/findings.md` as a flat list, one block per finding, separated by `---`.

## Why this exists
The harness must beat stock `/code-review`, not merely look more structured. Your output is the control. The lead session will diff your findings against the harness candidate pool before final validation. Any stock-only issue becomes a current-run validation lead, and missed patterns are also appended to `references/agent-prompts.md` so future hunters learn the pattern.

## Constraints
- Read-only. Do not edit any source files.
- Budget: ~30 min wall-clock. If the repo is huge, prioritize controllers + models touched by `@http.route`.
- One finding per real bug. No duplicates across files.
- Cite file:line. No hand-wavy "somewhere in this module".
"""
    (bs_dir / "dispatch.md").write_text(prompt, encoding="utf-8")
    (bs_dir / "README.md").write_text(
        "# Baseline Stock-CC Lane\n\n"
        "Lead Claude spawns one `general-purpose` Agent with the prompt in `dispatch.md`. The Agent writes `findings.md` here.\n\n"
        f"Note: {orchestration_note}\n\n"
        "Before final Phase 7/8 validation closes, run `scripts/odoo-review-stock-diff <OUT>` once the harness candidate `findings.json` exists. Treat stock-only entries in `diff.md` as validation leads for the current report, then optionally run `--apply-lessons` to append durable hunter lessons.\n",
        encoding="utf-8",
    )


def write_run_mode(out: Path, args: argparse.Namespace, repo: Path) -> None:
    """Emit run-mode.json + 00-run-mode.md so the lead Claude session can honor manual/full/non-interactive review flags."""
    mode = {
        "non_interactive": bool(getattr(args, "non_interactive", False)),
        "learn": bool(getattr(args, "learn", False)),
        "learn_cap": int(getattr(args, "learn_cap", 3)),
        "weekly": bool(getattr(args, "weekly", False)),
        "baseline_stock_cc": bool(getattr(args, "baseline_stock_cc", False)),
        "project_config": getattr(args, "project_config_loaded", None),
        "model_pack": getattr(args, "model_pack", "default"),
        "quick": bool(getattr(args, "quick", False)),
        "joern": bool(getattr(args, "joern", False)),
        "runtime": bool(getattr(args, "runtime", False)),
        "odoomap_target": getattr(args, "odoomap_target", None),
        "no_codex": bool(getattr(args, "no_codex", False)),
        "no_local_qwen": bool(getattr(args, "no_local_qwen", False)),
        "no_breadth": bool(getattr(args, "no_breadth", False)),
        "no_discourse": bool(getattr(args, "no_discourse", False)),
        "no_export": bool(getattr(args, "no_export", False)),
        "no_html": bool(getattr(args, "no_html", False)),
        "emit_json": bool(getattr(args, "emit_json", True)),
        "scope": args.scope,
        "baseline": args.baseline,
        "accepted_risks_override": getattr(args, "accepted_risks", None),
        "fix_list_override": getattr(args, "fix_list", None),
        "pr": args.pr,
        "pr_repo": args.pr_repo,
        "modules": args.modules,
        "odoo_version_override": args.odoo_version,
        "codex_model": args.codex_model,
        "codex_budget": args.codex_budget,
        "codex_mode": args.codex_mode,
        "ensemble": getattr(args, "ensemble", "off"),
        "ensemble_passes": getattr(args, "ensemble_passes", 0),
        "local_model": args.local_model,
        "breadth_budget": getattr(args, "breadth_budget", "normal"),
        "breadth_max_chunks": getattr(args, "breadth_max_chunks", 0),
        "breadth_chunk_size": args.breadth_chunk_size,
        "phase1_min_lines_per_module": args.phase1_min_lines_per_module,
        "no_phase1_assert": bool(getattr(args, "no_phase1_assert", False)),
        "allow_empty_scope": bool(getattr(args, "allow_empty_scope", False)),
        "allow_missing_lanes": bool(getattr(args, "allow_missing_lanes", False)),
        "preflight_only": bool(getattr(args, "preflight_only", False)),
        "no_scans": bool(getattr(args, "no_scans", False)),
        "no_server_actions": bool(getattr(args, "no_server_actions", False)),
        "no_scripts": bool(getattr(args, "no_scripts", False)),
        "repo": str(repo),
        "out": str(out),
    }
    (out / "run-mode.json").write_text(json.dumps(mode, indent=2, sort_keys=True), encoding="utf-8")

    md = ["# Run Mode\n"]
    md.append("Lead Claude session reads this file to decide whether to suppress y/N prompts and run the self-improving learn loop.\n")
    md.append("## Active flags\n")
    flag_lines = []
    if mode["weekly"]:
        flag_lines.append("- **-ks** — kitchen-sink max-quality mode")
    if mode["non_interactive"]:
        flag_lines.append("- **--yes** — strip every y/N prompt; with --learn, Phase 8.7 auto-applies accepted-risk suggestions")
    if mode["learn"]:
        flag_lines.append(f"- **--learn** — produce durable learning artifacts (cap: {mode['learn_cap']} iterations)")
    if mode["baseline_stock_cc"]:
        flag_lines.append("- **--baseline-stock-cc** — spawn stock-CC control lane, validate stock-only leads, append misses to hunter prompts")
    if mode["quick"]:
        flag_lines.append("- **--quick** — scanners + Phase 5.5 skipped")
    if mode["joern"]:
        flag_lines.append("- **--joern** — Phase 3.5 CPG graph review")
    if mode["runtime"]:
        flag_lines.append("- **--runtime** — Phase 7.5 runtime evidence helper path")
    if mode["odoomap_target"]:
        flag_lines.append(
            f"- **--odoomap-target {mode['odoomap_target']}** — optional authorized OdooMap runtime lead capture"
        )
    if mode["model_pack"] != "default":
        flag_lines.append(f"- **--model-pack {mode['model_pack']}** — model/lane preset")
    if mode["ensemble"] != "off":
        flag_lines.append(f"- **--ensemble {mode['ensemble']}** — focused recall ensemble (passes: {mode['ensemble_passes'] or 'preset'})")
    if mode["no_breadth"] or mode["breadth_budget"] == "off":
        flag_lines.append("- **--breadth-budget off** — Phase 1.7 Claude breadth subagents disabled")
    elif mode["breadth_budget"] != "normal" or mode["breadth_max_chunks"]:
        cap = mode["breadth_max_chunks"] or "preset"
        flag_lines.append(f"- **--breadth-budget {mode['breadth_budget']}** — Phase 1.7 Claude breadth subagents capped/prioritized (cap: {cap})")
    if not flag_lines:
        flag_lines.append("- (default mode — interactive prompts active)")
    md.extend(flag_lines)
    md.append("")
    md.append("## Orchestration contract\n")
    md.append("Lead Claude MUST honor these flags:\n")
    md.append("- `non_interactive=true` → never emit `[y/N]` prompts; choose the documented default action and proceed.")
    md.append("- `learn=true` → after Phase 8.6, run Phase 8.7 learning. Use `--apply` only when `non_interactive=true` or the user approved the suggestions.")
    md.append("- `baseline_stock_cc=true` → during Phase 1, dispatch one general-purpose Agent with stock-CC review prompt against the same repo; diff before final Phase 7/8 closure and validate stock-only leads in this run.")
    md.append("- `breadth_budget` controls Phase 1.7 Claude Agent spend. Dispatch only chunks listed in `inventory/breadth/dispatch.json`; they are risk-prioritized and may be intentionally capped.")
    md.append("")
    (out / "00-run-mode.md").write_text("\n".join(md), encoding="utf-8")


def main() -> int:
    args = parse_args()
    repo = Path(args.target).expanduser().resolve()
    if not repo.exists():
        print(f"Target does not exist: {repo}", file=sys.stderr)
        return 2
    config_data, config_path, config_warnings = apply_project_config(args, repo)
    args.project_config_loaded = str(config_path) if config_path else None
    args.project_config_warnings = config_warnings
    if args.zap_target and not args.runtime:
        print("--zap-target requires --runtime", file=sys.stderr)
        return 2
    if args.odoomap_target and not args.runtime:
        print("--odoomap-target requires --runtime", file=sys.stderr)
        return 2
    runtime_target_errors = validate_runtime_targets(args)
    if runtime_target_errors:
        for error in runtime_target_errors:
            print(error, file=sys.stderr)
        return 2
    autodetect_weekly_paths(args, repo)
    if args.out:
        out = Path(args.out).expanduser().resolve()
    else:
        stamp = dt.datetime.now().strftime("%Y%m%d-%H%M")
        out = repo / f".audit-{stamp}"
    out.mkdir(parents=True, exist_ok=True)
    for sub in ["inventory", "scans", "agents", "codex", "ensemble", "variants", "runtime", "attack-graphs", "requirements", "directives", "directives/results", "baseline-stock", "qwen-handoff"]:
        (out / sub).mkdir(parents=True, exist_ok=True)
    log_path = out / "commands.log"
    write_run_mode(out, args, repo)
    write_baseline_stock_dispatch(out, args, repo)

    plan, lane_errors = preflight(args, repo, out)
    if lane_errors and not args.allow_missing_lanes:
        write_tooling(out, plan, [], None, None)
        print("Preflight failed:")
        for error in lane_errors:
            print(f"- {error}")
        print(f"Run plan written to {out / 'tooling.md'}")
        return 3

    accepted_risks = load_accepted_risks(args, repo)
    write_accepted_risks_artifacts(out, accepted_risks)
    if accepted_risks["errors"]:
        print("Accepted-risks file has validation errors:")
        for err in accepted_risks["errors"]:
            print(f"- {err}")
        print(f"See {out / '00-accepted-risks.md'}")
        return 4
    if args.check_only_accepted_risks:
        expired = len(accepted_risks["expired"])
        stale = len(accepted_risks["stale"])
        print(f"Accepted-risks: active={len(accepted_risks['active'])} expired={expired} stale={stale}")
        print(f"Inventory: {out / 'inventory' / 'accepted-risks.json'}")
        print(f"Report: {out / '00-accepted-risks.md'}")
        return 1 if expired else 0

    fix_list = load_fix_list(args, repo)
    write_fix_list_artifacts(out, fix_list)
    if fix_list["errors"]:
        print("Fix-list file has validation errors:")
        for err in fix_list["errors"]:
            print(f"- {err}")
        print(f"See {out / '00-fix-list.md'}")
        return 5
    if args.check_only_fix_list:
        overdue = len(fix_list["overdue"])
        print(f"Fix-list: active={len(fix_list['active'])} overdue={overdue}")
        print(f"Inventory: {out / 'inventory' / 'fix-list.json'}")
        print(f"Report: {out / '00-fix-list.md'}")
        return 1 if overdue else 0

    allowed_modules = {part.strip() for part in args.modules.split(",") if part.strip()} if args.modules else None
    manifests = find_manifests(repo, allowed_modules)
    loose = find_loose_python(repo, args)
    if loose:
        print(f"Loose Python sweep: {len(loose)} pseudo-module(s) added (origins: {sorted({m.get('origin','?') for m in loose})})")
    manifests = manifests + loose

    scope_data: dict = {}
    if args.scope:
        scope_path = Path(args.scope).expanduser().resolve()
        if scope_path.exists():
            try:
                scope_data = parse_scope_yaml(scope_path)
                manifests = filter_manifests_by_scope(manifests, scope_data)
                print(f"Scope file applied: {scope_path}")
            except Exception as exc:  # noqa: BLE001
                print(f"WARN: could not parse scope file {scope_path}: {exc}", file=sys.stderr)
        else:
            print(f"WARN: --scope file not found: {scope_path}", file=sys.stderr)

    pr_files: list[str] = []
    if args.pr:
        pr_files = fetch_pr_files(args.pr, args.pr_repo, repo)
        if pr_files:
            manifests = filter_manifests_by_pr_files(manifests, pr_files)
            print(f"PR scope applied: {args.pr} ({len(pr_files)} files, {len(manifests)} module(s))")
        else:
            print(f"WARN: --pr {args.pr} returned no files (gh CLI unavailable or PR has no files)", file=sys.stderr)

    if not manifests and not args.allow_empty_scope:
        print("No Odoo modules or supported pseudo-modules were discovered in the target scope.")
        print(f"Target: {repo}")
        print("Refusing to continue before scanner/model lanes to avoid spending quota on the wrong directory.")
        print("Pass the Odoo addons path, use --modules/--scope differently, or add --allow-empty-scope to override.")
        write_tooling(out, plan, [], None, None)
        return 7

    routes = extract_routes(repo, manifests)
    acl_rows = index_acl(repo, manifests)
    pattern_summary = scan_patterns(repo, manifests)
    write_inventory(repo, out, manifests, routes, acl_rows, pattern_summary, args)
    risk_rows = compute_module_risk(manifests, routes, acl_rows, pattern_summary)
    write_module_risk(out, risk_rows)
    copy_cwe_map(out)
    write_goals_guide(repo, out, manifests, routes, args)
    write_directives_seed(out)
    write_qwen_handoff(out, args, repo)
    write_scope_artifact(out, scope_data, args, pr_files)
    write_runtime_probe_plan(out, routes, args)
    emit_breadth_dispatch(out, manifests, routes, pattern_summary, risk_rows, args)

    phase1_errors = assert_phase1_populated(out, manifests, args)
    if phase1_errors:
        print("Phase 1 fail-loud assertion FAILED:")
        for err in phase1_errors:
            print(f"- {err}")
        print(f"See {out / '01-attack-surface.md'}")
        print("Fix the inventory generation or pass --no-phase1-assert to skip (not recommended).")
        write_tooling(out, plan, [], None, None)
        return 6

    scanner_records: list[dict] = []
    qwen_record: dict | None = None
    codex_records: list[dict] | None = None
    ensemble_records: list[dict] | None = None
    if not args.preflight_only:
        scanner_records = run_scanners(args, repo, out, log_path)
        qwen_record = run_qwen(args, repo, out, log_path)
        codex_records = run_codex(args, repo, out, log_path)
        ensemble_records = run_ensemble(args, repo, out, log_path)
    else:
        ensemble_records = run_ensemble(args, repo, out, log_path)
    write_tooling(out, plan, scanner_records, qwen_record, codex_records, ensemble_records)

    print("odoo-review-run complete")
    print(f"Target: {repo}")
    print(f"Output: {out}")
    print(f"Modules: {len(manifests)}")
    print(f"Routes: {len(routes)}")
    print(f"Run plan: {out / 'tooling.md'}")
    print("Next: Claude should continue Phase 5.5/6/7 validation using the generated artifacts.")

    if args.prune_old_runs and args.prune_old_runs > 0:
        stamped = sorted(
            (p for p in repo.glob(".audit-*")
             if p.is_dir() and len(p.name) == len(".audit-YYYYMMDD-HHMM")
             and p.name[7:].replace("-", "").isdigit()),
            key=lambda p: p.name,
        )
        to_delete = stamped[: -args.prune_old_runs] if len(stamped) > args.prune_old_runs else []
        for old in to_delete:
            shutil.rmtree(old)
            print(f"Pruned old run: {old.name}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
