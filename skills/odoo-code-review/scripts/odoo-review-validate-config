#!/usr/bin/env python3
"""Wrapper for odoo-review-validate-config command."""
import sys
from pathlib import Path

repo_root = Path(__file__).resolve().parents[3]
if str(repo_root) not in sys.path:
    sys.path.insert(0, str(repo_root))

from odoo_security_harness.scripts.validate_config import main

if __name__ == "__main__":
    sys.exit(main())
